@{
    Layout = null;
    ViewData["Title"] = "Doğrulama";
    string channel = (ViewBag.Channel as string) ?? "Email";
    string channelLabel = channel == "Sms" ? "SMS" : channel == "Whatsapp" ? "WhatsApp" : "e-posta";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Doğrulama — vMon</title>
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" asp-append-version="true" />
    <script src="~/lib/tailwind/tailwind.js" asp-append-version="true"></script>
    <script>
        tailwind.config = { theme: { extend: { colors: { brand: { 400:'#f87171',500:'#ed1c24',600:'#d4151c' } } } } };
    </script>
    <style>
        body{background:radial-gradient(1200px 600px at 50% -10%, rgba(237,28,36,.12), transparent 60%), linear-gradient(160deg,#0f172a,#1e293b);}
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4 font-sans">
    <div class="w-full max-w-md">
        <div class="text-center mb-6">
            <div class="inline-flex items-center justify-center h-16 w-16 rounded-2xl bg-brand-500 shadow-lg shadow-brand-500/40 mb-3">
                <i class="bi bi-shield-lock text-white text-3xl"></i>
            </div>
            <h1 class="text-3xl font-bold text-white">İki Adımlı Doğrulama</h1>
            <p class="text-slate-400 mt-1">Kodu @channelLabel adresinize gönderdik</p>
        </div>

        <div class="bg-white rounded-2xl shadow-2xl p-8">
            @if (ViewBag.Error != null)
            {
                <div class="bg-rose-50 text-rose-700 border border-rose-200 rounded-xl px-4 py-3 mb-4 text-sm flex items-center gap-2">
                    <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error
                </div>
            }
            @if (ViewBag.Info != null)
            {
                <div class="bg-emerald-50 text-emerald-700 border border-emerald-200 rounded-xl px-4 py-3 mb-4 text-sm flex items-center gap-2">
                    <i class="bi bi-check-circle-fill"></i> @ViewBag.Info
                </div>
            }
            <form method="post" asp-action="VerifyOtp" class="space-y-4">
                @Html.AntiForgeryToken()
                <div>
                    <label class="block text-sm font-medium text-slate-600 mb-1.5">Doğrulama Kodu</label>
                    <input type="text" name="code" autofocus inputmode="numeric" pattern="[0-9]*" maxlength="6"
                           autocomplete="one-time-code" placeholder="● ● ● ● ● ●"
                           class="w-full text-center tracking-[0.5em] text-2xl rounded-xl border border-slate-300 px-3 py-3 focus:border-brand-400 focus:ring-2 focus:ring-brand-100 outline-none" />
                </div>
                <button class="w-full bg-brand-500 hover:bg-brand-600 text-white font-medium rounded-xl py-2.5 shadow-sm shadow-brand-500/30 transition">
                    <i class="bi bi-check2-circle"></i> Doğrula ve Giriş Yap
                </button>
            </form>
            <div class="flex items-center justify-between mt-5 text-xs">
                <form method="post" asp-action="ResendOtp">
                    @Html.AntiForgeryToken()
                    <button class="text-slate-500 hover:text-brand-600"><i class="bi bi-arrow-repeat"></i> Kodu yeniden gönder</button>
                </form>
                <a href="@Url.Action("Login")" class="text-slate-400 hover:text-slate-600"><i class="bi bi-arrow-left"></i> Girişe dön</a>
            </div>
            <p class="text-center text-slate-400 text-[11px] mt-4">Kod 5 dakika geçerlidir. Almadıysanız profilinizdeki iletişim bilgilerini kontrol edin.</p>
        </div>
    </div>
</body>
</html>

@model AppUser
@{
    ViewData["Title"] = "Yetki Düzenle";
    var perms = Model.Permissions();
    bool isAdmin = ViewBag.IsAdmin == true;
}

<h1 class="text-2xl font-bold text-slate-800 flex items-center gap-2 mb-1"><i class="bi bi-person-gear text-brand-500"></i> Yetki Düzenle</h1>
<p class="text-slate-500 mb-5"><span class="mono">@Model.Sam</span> @(string.IsNullOrWhiteSpace(Model.DisplayName) ? "" : "— " + Model.DisplayName)</p>

<div class="card max-w-2xl">
    <div class="card-body">
        @if (isAdmin)
        {
            <div class="alert-warn text-sm">Bu kullanıcı admin listesinde — tüm yetkilere sahiptir, burada düzenlenemez.</div>
        }
        else
        {
            <form method="post" asp-action="Save" asp-route-id="@Model.Id" class="space-y-3">
                @Html.AntiForgeryToken()
                <div>
                    <label class="label">Telefon (WhatsApp/SMS interaktif + OTP için)</label>
                    <input type="text" name="phone" value="@Model.Phone" class="input mono max-w-xs" placeholder="+905321234567" />
                    <div class="hint">Bu numaradan gelen WhatsApp buton komutları bu kullanıcıyla eşlenir; işlem yapabilmesi için aşağıdaki <b>"Alarmlara müdahale"</b> yetkisi gerekir. SMS/WhatsApp OTP de bu numaraya gider.</div>
                </div>
                <div>
                    <label class="label">E-posta (OTP: E-posta kanalı için)</label>
                    <input type="email" name="email" value="@Model.Email" class="input mono max-w-xs" placeholder="ad.soyad@firma.com" />
                </div>
                <p class="text-sm text-slate-600 mb-2">Kullanıcının erişebileceği yetenekleri işaretleyin:</p>
                @foreach (var p in Perms.All)
                {
                    <label class="flex items-start gap-3 p-3 rounded-xl border border-slate-200 hover:bg-slate-50 cursor-pointer">
                        <input type="checkbox" name="perms" value="@p.Key" class="switch mt-0.5" @(perms.Contains(p.Key) ? "checked" : "") />
                        <span>
                            <span class="font-medium text-slate-800">@p.Label</span>
                            <span class="block mono text-xs text-slate-400">@p.Key</span>
                        </span>
                    </label>
                }
                <div class="flex gap-2 pt-2">
                    <button class="btn btn-primary"><i class="bi bi-save"></i> Kaydet</button>
                    <a class="btn btn-outline" asp-action="Index">İptal</a>
                </div>
                <div class="hint">Değişiklikler kullanıcının bir sonraki girişinde geçerli olur.</div>
            </form>
        }
    </div>
</div>

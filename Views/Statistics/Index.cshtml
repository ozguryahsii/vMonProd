@model List<vMonitor.Models.StatWidget>
@{
    ViewData["Title"] = "İstatistikler";
    bool canEdit = ViewBag.CanEdit == true;
}
<link rel="stylesheet" href="~/lib/gridstack/gridstack.min.css" asp-append-version="true" />
<style>
    .grid-stack { background: transparent; }
    .grid-stack-item-content { inset: 6px; border-radius: 1rem; overflow: hidden; }
    .stat-card { height:100%; background:#fff; border:1px solid #e2e8f0; border-radius:1rem; padding:1rem 1.1rem;
        display:flex; flex-direction:column; box-shadow:0 1px 2px rgba(15,23,42,.04); position:relative; }
    .stat-card h3 { font-size:.78rem; font-weight:600; color:#64748b; letter-spacing:.02em; display:flex; align-items:center; gap:.4rem; }
    .stat-num { font-size:2.4rem; font-weight:800; line-height:1; }
    .stat-sub { font-size:.78rem; color:#94a3b8; }
    .stat-chart { flex:1; min-height:0; }
    .stat-bar { height:.5rem; border-radius:999px; background:#f1f5f9; overflow:hidden; }
    .stat-bar > div { height:100%; border-radius:999px; transition:width 1.1s cubic-bezier(.22,1,.36,1); }
    .wremove { position:absolute; top:.4rem; right:.4rem; display:none; }
    .stats-editing .wremove { display:inline-flex; }
    .stats-editing .grid-stack-item-content { outline:2px dashed #cbd5e1; cursor:move; }
    .grid-stack-item-content::-webkit-scrollbar { display:none; }
    .stat-card { cursor:pointer; }
    .stat-card:hover { box-shadow:0 4px 14px rgba(15,23,42,.08); }
    /* Koyu tema */
    .dark .stat-card { background:#1e293b; border-color:#334155; box-shadow:none; }
    .dark .stat-card:hover { box-shadow:0 4px 14px rgba(0,0,0,.4); }
    .dark .stat-card h3 { color:#94a3b8; }
    .dark .stat-sub { color:#64748b; }
    .dark .stat-bar { background:#334155; }
    .dark .stats-editing .grid-stack-item-content { outline-color:#475569; }
    /* Detay modalı */
    .smodal { position:fixed; inset:0; background:rgba(15,23,42,.55); z-index:60; display:none; align-items:center; justify-content:center; padding:1rem; }
    .smodal.open { display:flex; }
    .smodal-panel { background:#fff; border-radius:1rem; width:100%; max-width:56rem; max-height:86vh; display:flex; flex-direction:column; overflow:hidden; }
    .dark .smodal-panel { background:#1e293b; color:#e2e8f0; }
    .smodal-head { display:flex; align-items:center; justify-content:space-between; padding:1rem 1.25rem; border-bottom:1px solid #e2e8f0; }
    .dark .smodal-head { border-color:#334155; }
    .smodal-body { padding:1rem 1.25rem; overflow:auto; }
    .stbl { width:100%; font-size:.82rem; border-collapse:collapse; }
    .stbl th, .stbl td { text-align:left; padding:.45rem .6rem; border-bottom:1px solid #f1f5f9; white-space:nowrap; }
    .dark .stbl th, .dark .stbl td { border-color:#334155; }
    .stbl th { color:#64748b; font-weight:600; position:sticky; top:0; background:inherit; }
    /* Kategori dökümü (breakdown) barlari */
    .brk-list { display:flex; flex-direction:column; gap:.35rem; }
    .brk-row { display:grid; grid-template-columns:12rem 1fr 3.2rem; align-items:center; gap:.7rem; width:100%; text-align:left; padding:.4rem .55rem; border-radius:.55rem; background:transparent; border:0; cursor:pointer; }
    .brk-row:hover { background:#f1f5f9; }
    .dark .brk-row:hover { background:#0f172a; }
    .brk-name { font-size:.84rem; color:inherit; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .brk-bar { height:.7rem; background:#eef2f7; border-radius:999px; overflow:hidden; }
    .dark .brk-bar { background:#334155; }
    .brk-bar > span { display:block; height:100%; border-radius:999px; transition:width .9s cubic-bezier(.22,1,.36,1); }
    .brk-val { text-align:right; font-weight:700; font-size:.9rem; }
</style>

<div class="flex flex-wrap items-center justify-between gap-3 mb-4">
    <div>
        <h1 class="text-2xl font-bold text-slate-800 flex items-center gap-2"><i class="bi bi-bar-chart-line text-brand-500"></i> <span data-i18n="stats.title">İstatistikler</span></h1>
        <p class="text-sm text-slate-500 mt-0.5" data-i18n="stats.subtitle">İzlenen altyapının canlı özeti — filtrelenebilir, sürüklenebilir panolar</p>
    </div>
    <div class="flex items-center gap-2">
        <span id="lastUpd" class="text-xs text-slate-400 hidden sm:inline"></span>
        <button id="btnExport" class="btn btn-outline btn-sm" title="Özet CSV indir"><i class="bi bi-filetype-csv"></i></button>
        <button id="btnFull" class="btn btn-outline btn-sm" title="Tam ekran"><i class="bi bi-arrows-fullscreen"></i></button>
        <button id="btnRefresh" class="btn btn-outline btn-sm"><i class="bi bi-arrow-clockwise"></i> <span data-i18n="stats.refresh">Yenile</span></button>
        @if (canEdit)
        {
            <div id="editTools" class="hidden flex items-center gap-2">
                <select id="addType" class="input !py-1.5 !text-xs max-w-[12rem]">
                    <optgroup label="Sayaç">
                        <option value="counter|total_servers">Toplam sunucu</option>
                        <option value="counter|up">Up sayısı</option>
                        <option value="counter|down">Down sayısı</option>
                        <option value="counter|error">Hatalı sayısı</option>
                    </optgroup>
                    <optgroup label="Kaynak (kullanılan/atanan)">
                        <option value="resource|cpu">CPU</option>
                        <option value="resource|ram">RAM</option>
                        <option value="resource|disk">Disk</option>
                    </optgroup>
                    <optgroup label="Pasta">
                        <option value="pie|os_kind">OS dağılımı (Windows/Linux)</option>
                        <option value="pie|os_version">OS sürümleri</option>
                        <option value="pie|tag">Etiket (Tag) dağılımı</option>
                    </optgroup>
                    <optgroup label="Gösterge">
                        <option value="gauge|avg_cpu">Ort. CPU %</option>
                        <option value="gauge|avg_ram">Ort. RAM %</option>
                        <option value="gauge|avg_disk">Ort. Disk %</option>
                    </optgroup>
                    <optgroup label="İçgörü">
                        <option value="fleet|fleet">Filo trendi (30 gün)</option>
                        <option value="top|top">Top kaynak tüketenler</option>
                        <option value="critical|critical">Kritik durum</option>
                        <option value="uptime|uptime">Erişilebilirlik (uptime)</option>
                        <option value="histogram|histogram">Kullanım dağılımı</option>
                        <option value="capacity|capacity">Kapasite (kullanılan/atanan)</option>
                        <option value="outage|outage">Kesinti özeti</option>
                        <option value="os_eol|os_eol">Destek sonu (EOL) OS</option>
                        <option value="heatmap|heatmap">CPU ısı haritası</option>
                    </optgroup>
                </select>
                <button id="btnAdd" class="btn btn-outline btn-sm"><i class="bi bi-plus-lg"></i> Ekle</button>
                <button id="btnReset" class="btn btn-outline btn-sm" title="Tüm widget'ları varsayılana sıfırla"><i class="bi bi-arrow-counterclockwise"></i> Varsayılana dön</button>
                <button id="btnSave" class="btn btn-primary btn-sm"><i class="bi bi-save"></i> Kaydet</button>
            </div>
            <button id="btnEdit" class="btn btn-outline btn-sm" title="Düzenleme kilidini aç/kapat">
                <i class="bi bi-lock-fill"></i> <span id="editLabel">Düzenle</span>
            </button>
        }
    </div>
</div>

@Html.AntiForgeryToken()

<div class="grid-stack">
    @foreach (var w in Model)
    {
        <div class="grid-stack-item" gs-x="@w.X" gs-y="@w.Y" gs-w="@w.W" gs-h="@w.H"
             data-id="@w.Id" data-type="@w.Type" data-source="@w.Source" data-config="@(w.ConfigJson ?? "")">
            <div class="grid-stack-item-content">
                <div class="stat-card">
                    @if (canEdit)
                    {
                        <button class="wremove btn btn-danger btn-sm" type="button" onclick="removeWidget(this)"><i class="bi bi-x-lg"></i></button>
                    }
                    <div class="widget-body" style="flex:1; display:flex; flex-direction:column; min-height:0;"></div>
                </div>
            </div>
        </div>
    }
</div>

<div id="smodal" class="smodal">
    <div class="smodal-panel">
        <div class="smodal-head">
            <h3 id="smTitle" class="font-semibold text-slate-800 dark:text-slate-100 flex items-center gap-2"><i class="bi bi-list-ul text-brand-500"></i> <span>Detay</span></h3>
            <button onclick="closeDetail()" class="btn btn-outline btn-sm"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="smodal-body">
            <div id="smRange" class="hidden flex flex-wrap gap-1.5 mb-2">
                <button class="btn btn-outline btn-sm sm-range" data-days="7">7 gün</button>
                <button class="btn btn-outline btn-sm sm-range" data-days="30">1 ay</button>
                <button class="btn btn-outline btn-sm sm-range" data-days="90">3 ay</button>
                <button class="btn btn-outline btn-sm sm-range" data-days="180">6 ay</button>
                <button class="btn btn-outline btn-sm sm-range" data-days="365">1 yıl</button>
            </div>
            <div id="smTrend" class="hidden mb-4" style="height:220px;"></div>
            <div id="smTableWrap" class="overflow-auto" style="max-height:42vh;"></div>
        </div>
    </div>
</div>

<script src="~/lib/echarts/echarts.min.js" asp-append-version="true"></script>
<script src="~/lib/gridstack/gridstack-all.js" asp-append-version="true"></script>
<script src="~/lib/countup/countUp.umd.js" asp-append-version="true"></script>
<script>
(function () {
    const canEdit = @(canEdit ? "true" : "false");
    const PALETTE = ['#ed1c24','#3b82f6','#10b981','#f59e0b','#8b5cf6','#ec4899','#14b8a6','#f97316','#6366f1','#84cc16'];
    const META = {
        total_servers: { label:'Toplam Sunucu', icon:'bi-hdd-network', color:'#3b82f6' },
        up:    { label:'Up (Sorunsuz)', icon:'bi-check-circle', color:'#10b981' },
        down:  { label:'Down (Erişilemiyor)', icon:'bi-x-circle', color:'#ef4444' },
        error: { label:'Hata / Eşik', icon:'bi-exclamation-triangle', color:'#f59e0b' },
        cpu:   { label:'CPU (kullanılan / atanan)', icon:'bi-cpu', color:'#ed1c24' },
        ram:   { label:'RAM (kullanılan / atanan)', icon:'bi-memory', color:'#8b5cf6' },
        disk:  { label:'Disk (kullanılan / atanan)', icon:'bi-device-hdd', color:'#14b8a6' },
        os_kind:    { label:'İşletim Sistemi Dağılımı', icon:'bi-pc-display', color:'#3b82f6' },
        os_version: { label:'OS Sürümleri', icon:'bi-windows', color:'#6366f1' },
        tag:        { label:'Etiket (Tag) Dağılımı', icon:'bi-tags', color:'#ec4899' },
        avg_cpu:  { label:'Ortalama CPU %', icon:'bi-cpu', color:'#ed1c24' },
        avg_ram:  { label:'Ortalama RAM %', icon:'bi-memory', color:'#8b5cf6' },
        avg_disk: { label:'Ortalama Disk %', icon:'bi-device-hdd', color:'#14b8a6' },
        fleet:    { label:'Filo Trendi — Ort. CPU/RAM/Disk (30 gün)', icon:'bi-graph-up', color:'#3b82f6' },
        top:      { label:'Top Kaynak Tüketenler', icon:'bi-fire', color:'#ef4444' },
        critical: { label:'Kritik Durum', icon:'bi-exclamation-octagon', color:'#ef4444' },
        uptime:   { label:'Erişilebilirlik (Uptime)', icon:'bi-shield-check', color:'#10b981' },
        histogram:{ label:'Kullanım Dağılımı', icon:'bi-bar-chart-steps', color:'#8b5cf6' },
        capacity: { label:'Kapasite (kullanılan / atanan)', icon:'bi-hdd-stack', color:'#14b8a6' },
        outage:   { label:'Kesinti Özeti (7 gün)', icon:'bi-plug', color:'#f59e0b' },
        os_eol:   { label:'Destek Sonu (EOL) OS', icon:'bi-shield-exclamation', color:'#ef4444' },
        heatmap:  { label:'CPU Isı Haritası (24s)', icon:'bi-grid-3x3', color:'#3b82f6' },
        disk_full:{ label:'Diski Dolmak Üzere (%85+)', icon:'bi-device-hdd-fill', color:'#ef4444' },
    };
    const charts = {};   // elId -> echarts instance
    let DATA = null;
    let editing = false;
    const isDark = () => document.documentElement.classList.contains('dark');
    const txtColor = () => isDark() ? '#cbd5e1' : '#334155';
    const trackColor = () => isDark() ? '#334155' : '#f1f5f9';
    let modalChart = null;
    const esc = s => (s==null?'':String(s)).replace(/[&<>"]/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
    const pct = v => (v==null?'—':(Math.round(v*10)/10)+'%');
    function statusBadge(s){
        const c = s==='Up'?'#10b981': s==='Down'?'#ef4444': s==='Hata'?'#f59e0b':'#94a3b8';
        return '<span style="color:'+c+';font-weight:600">'+esc(s)+'</span>';
    }
    function bindCardClick(item, fn){
        const card = item.querySelector('.stat-card');
        if (card) card.onclick = () => { if (!editing) fn(); };
    }
    function tabRow(tabs, active){
        return '<div class="flex gap-1 mb-2">' + tabs.map(k =>
            '<button class="px-2 py-0.5 rounded text-xs '+(k===active?'bg-brand-500 text-white':'text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-700')+'" data-tab="'+k+'">'+k.toUpperCase()+'</button>').join('') + '</div>';
    }
    function bindTabs(body, item, prop){
        body.querySelectorAll('[data-tab]').forEach(b => b.addEventListener('click', e => { e.stopPropagation(); item[prop] = b.dataset.tab; renderWidget(item); }));
    }
    const upColor = v => v>=99.5 ? '#10b981' : v>=98 ? '#f59e0b' : '#ef4444';
    function barList(arr, color, suffix){
        const max = Math.max(1, ...arr.map(x=>x.value));
        return arr.length ? arr.map(d=>'<div class="brk-row" style="cursor:default">'
            +'<span class="brk-name" title="'+esc(d.name)+'">'+esc(d.name)+'</span>'
            +'<span class="brk-bar"><span style="width:'+Math.round(100*d.value/max)+'%;background:'+color+'"></span></span>'
            +'<span class="brk-val">'+d.value+(suffix||'')+'</span></div>').join('') : '<div class="stat-sub">Veri yok.</div>';
    }

    const grid = GridStack.init({ column:12, cellHeight:70, margin:6, float:true,
        disableDrag:true, disableResize:true, handle:'.grid-stack-item-content' });

    function fmt(n){ return (n==null)?'—':(Math.round(n*10)/10).toLocaleString('tr-TR'); }

    function ensureId(el){ if(!el.__cid) el.__cid = 'c'+Math.random().toString(36).slice(2); return el.__cid; }

    function chartFor(host){
        const id = ensureId(host);
        if (charts[id]) { charts[id].dispose(); }
        charts[id] = echarts.init(host, null, { renderer:'canvas' });
        return charts[id];
    }

    function header(meta){
        return '<h3><i class="bi '+meta.icon+'" style="color:'+meta.color+'"></i> '+ (meta.label||'') +'</h3>';
    }

    function renderWidget(item){
        const type = item.getAttribute('data-type');
        const source = item.getAttribute('data-source');
        const body = item.querySelector('.widget-body');
        const meta = META[source] || { label:source, icon:'bi-grid', color:'#64748b' };
        if (!DATA) { body.innerHTML = header(meta)+'<div class="stat-sub mt-2">Yükleniyor…</div>'; return; }

        if (type === 'counter') {
            const cmap = { total_servers:'total', up:'up', down:'down', error:'error' };
            const v = (DATA.counts||{})[cmap[source]||source] ?? 0;
            body.innerHTML = header(meta) + '<div class="flex-1 flex items-center"><div class="stat-num" style="color:'+meta.color+'">0</div></div>';
            const num = body.querySelector('.stat-num');
            new countUp.CountUp(num, v, { duration:1.2, separator:'.' }).start();
            bindCardClick(item, () => openDetail(source, null));
            return;
        }
        if (type === 'resource') {
            const r = (DATA[source]||{used:0,alloc:0,unit:''});
            const pct = r.alloc > 0 ? Math.min(100, Math.round(100*r.used/r.alloc)) : 0;
            body.innerHTML = header(meta) +
                '<div class="flex-1 flex flex-col justify-center gap-2">' +
                  '<div><span class="stat-num" style="color:'+meta.color+'">'+fmt(r.used)+'</span>' +
                  '<span class="stat-sub"> / '+fmt(r.alloc)+' '+r.unit+'</span></div>' +
                  '<div class="stat-bar"><div style="width:0%;background:linear-gradient(90deg,'+meta.color+'aa,'+meta.color+')"></div></div>' +
                  '<div class="stat-sub">%'+pct+' kullanım</div>' +
                  '<div class="stat-spark" style="height:30px;margin-top:2px"></div>' +
                '</div>';
            const num = body.querySelector('.stat-num');
            num.textContent = '0';
            new countUp.CountUp(num, r.used, { duration:1.2, decimalPlaces:(r.used%1?1:0), separator:'.' }).start();
            requestAnimationFrame(()=>{ body.querySelector('.stat-bar>div').style.width = pct+'%'; });
            // mini sparkline: filo trendinden bu metriğin son günleri (cpu/ram/disk %)
            const spark = (DATA.fleet||[]).map(p=>p[source]).filter(v=>v!=null).slice(-14);
            if (spark.length) {
                const ch = chartFor(body.querySelector('.stat-spark'));
                ch.setOption({ grid:{left:0,right:0,top:2,bottom:2}, xAxis:{type:'category',show:false,data:spark.map((_,i)=>i)},
                    yAxis:{type:'value',show:false,max:100}, tooltip:{show:false},
                    series:[{type:'line',data:spark,smooth:true,symbol:'none',lineStyle:{color:meta.color,width:2},areaStyle:{color:meta.color,opacity:.12}}] });
            }
            bindCardClick(item, () => openDetail(source, null));
            return;
        }
        if (type === 'pie') {
            let arr = source==='os_kind' ? DATA.osKind : source==='os_version' ? DATA.osVersion : DATA.tags;
            arr = (arr||[]).slice();
            // tag widget: config.tags varsa filtrele
            if (source==='tag') {
                try { const cfg = JSON.parse(item.getAttribute('data-config')||'{}'); if (cfg.tags && cfg.tags.length) arr = arr.filter(x=>cfg.tags.includes(x.name)); } catch(e){}
            }
            const total = arr.reduce((a,b)=>a+b.value,0);
            body.innerHTML = header(meta) + '<div class="stat-chart"></div>';
            const host = body.querySelector('.stat-chart');
            const ch = chartFor(host);
            ch.setOption({
                tooltip:{ trigger:'item', formatter:'{b}: {c} (%{d})', appendToBody:true, confine:false },
                legend:{ type:'scroll', bottom:0, left:'center', textStyle:{fontSize:10,color:txtColor()},
                         pageTextStyle:{color:txtColor()} },
                series:[{ type:'pie', radius:['45%','72%'], center:['50%','46%'], avoidLabelOverlap:true,
                    itemStyle:{ borderColor: isDark()?'#1e293b':'#fff', borderWidth:2, borderRadius:4 },
                    label:{ show:false }, labelLine:{show:false},
                    data: arr.length ? arr.map((d,i)=>({ name:d.name, value:d.value, itemStyle:{color:PALETTE[i%PALETTE.length]} }))
                                     : [{name:'Veri yok',value:1, itemStyle:{color:'#e2e8f0'}}],
                    animationType:'scale', animationEasing:'elasticOut'
                }],
                graphic: total ? [{ type:'text', left:'center', top:'40%', style:{ text:total, fontSize:22, fontWeight:'bold', fill:txtColor() }}] : []
            });
            // Pasta dilimine/merkeze/karta tıkla → kategori dökümü (sayısal bar listesi), oradan sunuculara in
            ch.off('click').on('click', () => openBreakdown(source));
            bindCardClick(item, () => openBreakdown(source));
            return;
        }
        if (type === 'gauge') {
            const key = source.replace('avg_','');
            const v = (DATA.avg||{})[key];
            body.innerHTML = header(meta) + '<div class="stat-chart"></div>';
            const host = body.querySelector('.stat-chart');
            const ch = chartFor(host);
            ch.setOption({
                series:[{ type:'gauge', startAngle:210, endAngle:-30, min:0, max:100, radius:'92%', center:['50%','58%'],
                    progress:{ show:true, width:12, itemStyle:{color:meta.color} },
                    axisLine:{ lineStyle:{ width:12, color:[[1,trackColor()]] } },
                    axisTick:{show:false}, splitLine:{show:false}, axisLabel:{show:false}, pointer:{show:false},
                    anchor:{show:false},
                    detail:{ valueAnimation:true, fontSize:26, fontWeight:'bolder', offsetCenter:[0,'0%'], color:meta.color,
                        formatter: v==null ? '—' : '{value}%' },
                    data:[{ value: v==null?0:v }]
                }]
            });
            ch.off('click').on('click', () => openDetail(source, null));
            return;
        }
        if (type === 'fleet') {
            const f = DATA.fleet || [];
            body.innerHTML = header(meta) + '<div class="stat-chart"></div>';
            const ch = chartFor(body.querySelector('.stat-chart'));
            ch.setOption({
                tooltip:{ trigger:'axis' },
                legend:{ bottom:0, data:['CPU','RAM','Disk'], textStyle:{color:txtColor()} },
                grid:{ left:38, right:16, top:14, bottom:30 },
                xAxis:{ type:'category', data:f.map(p=>p.day), axisLabel:{color:txtColor()} },
                yAxis:{ type:'value', max:100, axisLabel:{color:txtColor()}, splitLine:{lineStyle:{color:trackColor()}} },
                series:[
                    { name:'CPU', type:'line', smooth:true, areaStyle:{opacity:.12}, data:f.map(p=>p.cpu), itemStyle:{color:'#ed1c24'}, lineStyle:{color:'#ed1c24'} },
                    { name:'RAM', type:'line', smooth:true, areaStyle:{opacity:.12}, data:f.map(p=>p.ram), itemStyle:{color:'#8b5cf6'}, lineStyle:{color:'#8b5cf6'} },
                    { name:'Disk', type:'line', smooth:true, areaStyle:{opacity:.12}, data:f.map(p=>p.disk), itemStyle:{color:'#14b8a6'}, lineStyle:{color:'#14b8a6'} }
                ]
            });
            return;
        }
        if (type === 'top') {
            const t = item.__topTab || 'cpu';
            const arr = (DATA.top && DATA.top[t]) || [];
            body.innerHTML = header(meta) + tabRow(['cpu','ram','disk'], t) + '<div class="brk-list" style="overflow:auto;flex:1">' + barList(arr, meta.color, '%') + '</div>';
            bindTabs(body, item, '__topTab');
            return;
        }
        if (type === 'critical') {
            const c = DATA.critical || { diskFull:0, breach:0 };
            body.innerHTML = header(meta) + '<div class="flex-1 grid grid-cols-2 gap-3 items-center text-center">'
                + '<button data-k="disk_full"><div class="stat-num" style="color:#ef4444">'+c.diskFull+'</div><div class="stat-sub">Disk %85+</div></button>'
                + '<button data-k="error"><div class="stat-num" style="color:#f59e0b">'+c.breach+'</div><div class="stat-sub">Eşik aşan (Error)</div></button></div>';
            body.querySelector('[data-k="disk_full"]').onclick = e => { e.stopPropagation(); openDetail('disk_full', null); };
            body.querySelector('[data-k="error"]').onclick = e => { e.stopPropagation(); openDetail('error', null); };
            return;
        }
        if (type === 'uptime') {
            const u = DATA.uptime || { h24:100, d7:100 };
            body.innerHTML = header(meta) + '<div class="flex-1 grid grid-cols-2 gap-3 items-center text-center">'
                + '<div><div class="stat-num" style="color:'+upColor(u.h24)+'">'+u.h24+'%</div><div class="stat-sub">Son 24 saat</div></div>'
                + '<div><div class="stat-num" style="color:'+upColor(u.d7)+'">'+u.d7+'%</div><div class="stat-sub">Son 7 gün</div></div></div>';
            return;
        }
        if (type === 'histogram') {
            const t = item.__hTab || 'cpu';
            const arr = (DATA.histogram && DATA.histogram[t]) || [0,0,0,0,0];
            const labels = ['0-20','20-40','40-60','60-80','80-100'];
            body.innerHTML = header(meta) + tabRow(['cpu','ram','disk'], t) + '<div class="stat-chart"></div>';
            bindTabs(body, item, '__hTab');
            const ch = chartFor(body.querySelector('.stat-chart'));
            ch.setOption({
                tooltip:{}, grid:{ left:30, right:12, top:10, bottom:22 },
                xAxis:{ type:'category', data:labels, axisLabel:{color:txtColor(),fontSize:10} },
                yAxis:{ type:'value', axisLabel:{color:txtColor()}, splitLine:{lineStyle:{color:trackColor()}} },
                series:[{ type:'bar', barWidth:'55%', data:arr.map((v,i)=>({ value:v, itemStyle:{ color:PALETTE[i], borderRadius:[4,4,0,0] } })) }]
            });
            return;
        }
        if (type === 'capacity') {
            const t = item.__cTab || 'ram';
            const cap = DATA.capacity || [];
            const used = cap.map(p => t==='ram'?p.ramUsed:p.diskUsed);
            const alloc = cap.map(p => t==='ram'?p.ramAlloc:p.diskAlloc);
            body.innerHTML = header(meta) + tabRow(['ram','disk'], t) + '<div class="stat-chart"></div>';
            bindTabs(body, item, '__cTab');
            const ch = chartFor(body.querySelector('.stat-chart'));
            ch.setOption({
                tooltip:{ trigger:'axis' }, legend:{ bottom:0, data:['Atanan','Kullanılan'], textStyle:{color:txtColor()} },
                grid:{ left:46, right:14, top:12, bottom:30 },
                xAxis:{ type:'category', data:cap.map(p=>p.day), axisLabel:{color:txtColor()} },
                yAxis:{ type:'value', name:'GB', axisLabel:{color:txtColor()}, splitLine:{lineStyle:{color:trackColor()}} },
                series:[
                    { name:'Atanan', type:'line', smooth:true, areaStyle:{opacity:.08}, data:alloc, itemStyle:{color:'#94a3b8'}, lineStyle:{color:'#94a3b8'} },
                    { name:'Kullanılan', type:'line', smooth:true, areaStyle:{opacity:.22}, data:used, itemStyle:{color:meta.color}, lineStyle:{color:meta.color} }
                ]
            });
            return;
        }
        if (type === 'outage') {
            const o = DATA.outages || { count:0, minutes:0, daily:[], worst:[] };
            body.innerHTML = header(meta)
                + '<div class="flex gap-5 my-1"><div><span class="stat-num" style="font-size:1.7rem;color:'+meta.color+'">'+o.count+'</span><span class="stat-sub"> kesinti</span></div>'
                + '<div><span class="stat-num" style="font-size:1.7rem">'+o.minutes+'</span><span class="stat-sub"> dk toplam</span></div></div>'
                + '<div class="stat-chart"></div>';
            const ch = chartFor(body.querySelector('.stat-chart'));
            ch.setOption({
                tooltip:{ trigger:'axis' }, grid:{ left:30, right:12, top:8, bottom:22 },
                xAxis:{ type:'category', data:(o.daily||[]).map(p=>p.day), axisLabel:{color:txtColor()} },
                yAxis:{ type:'value', axisLabel:{color:txtColor()}, splitLine:{lineStyle:{color:trackColor()}} },
                series:[{ type:'bar', barWidth:'50%', data:(o.daily||[]).map(p=>p.value), itemStyle:{ color:meta.color, borderRadius:[4,4,0,0] } }]
            });
            return;
        }
        if (type === 'os_eol') {
            const e = DATA.osEol || { count:0, items:[] };
            const list = (e.items||[]).map(d=>'<div class="flex items-center justify-between text-xs py-1 border-b border-slate-100 dark:border-slate-700"><span class="truncate" title="'+esc(d.name)+'">'+esc(d.name)+'</span><span class="badge pill-error ml-2">'+d.value+'</span></div>').join('') || '<div class="stat-sub">EOL sürüm yok 👍</div>';
            body.innerHTML = header(meta) + '<div class="stat-num" style="color:#ef4444">'+e.count+'</div><div class="stat-sub mb-2">destek sonu sunucu</div><div style="overflow:auto;flex:1">'+list+'</div>';
            return;
        }
        if (type === 'heatmap') {
            const h = DATA.heatmap || { rows:[], data:[] };
            const hours = Array.from({length:24},(_,i)=>String(i).padStart(2,'0'));
            body.innerHTML = header(meta) + '<div class="stat-chart"></div>';
            const ch = chartFor(body.querySelector('.stat-chart'));
            ch.setOption({
                tooltip:{ position:'top', formatter:p=> (h.rows[p.value[1]]||'')+' · '+hours[p.value[0]]+':00 → %'+p.value[2] },
                grid:{ left:130, right:14, top:8, bottom:18 },
                xAxis:{ type:'category', data:hours, splitArea:{show:true}, axisLabel:{color:txtColor(),fontSize:9} },
                yAxis:{ type:'category', data:h.rows, axisLabel:{color:txtColor(),fontSize:9}, splitArea:{show:true} },
                visualMap:{ min:0, max:100, show:false, inRange:{ color:['#dbeafe','#fde68a','#f87171','#dc2626'] } },
                series:[{ type:'heatmap', data:h.data, itemStyle:{borderColor:isDark()?'#1e293b':'#fff',borderWidth:1}, emphasis:{itemStyle:{borderColor:'#334155',borderWidth:1}} }]
            });
            return;
        }
        body.innerHTML = header(meta)+'<div class="stat-sub mt-2">Bilinmeyen widget</div>';
    }

    function renderAll(){
        Object.values(charts).forEach(c => { try { c.dispose(); } catch(e){} });
        for (const k in charts) delete charts[k];
        document.querySelectorAll('.grid-stack-item').forEach(renderWidget);
    }
    function resizeAll(){ Object.values(charts).forEach(c=>{ try{c.resize();}catch(e){} }); }

    async function load(){
        try {
            const r = await fetch('@Url.Action("Data")', { headers:{'X-Requested-With':'fetch'} });
            DATA = await r.json();
        } catch(e){ DATA = null; }
        renderAll();
        if (DATA && DATA.lastUpdated)
            document.getElementById('lastUpd').textContent = 'Son güncelleme: ' + new Date(DATA.lastUpdated).toLocaleTimeString('tr-TR');
    }

    function exportCsv(){
        if (!DATA) return;
        const rows = [['Metrik','Değer'],
            ['Toplam sunucu', DATA.counts.total], ['Up', DATA.counts.up], ['Down', DATA.counts.down], ['Error', DATA.counts.error],
            ['CPU kullanılan (çekirdek)', DATA.cpu.used], ['CPU atanan (çekirdek)', DATA.cpu.alloc],
            ['RAM kullanılan (GB)', DATA.ram.used], ['RAM atanan (GB)', DATA.ram.alloc],
            ['Disk kullanılan (GB)', DATA.disk.used], ['Disk atanan (GB)', DATA.disk.alloc],
            ['Ort. CPU %', DATA.avg.cpu], ['Ort. RAM %', DATA.avg.ram], ['Ort. Disk %', DATA.avg.disk],
            ['Uptime 24s %', DATA.uptime.h24], ['Uptime 7g %', DATA.uptime.d7],
            ['Kesinti (7g)', DATA.outages.count], ['Kesinti dk (7g)', DATA.outages.minutes],
            ['EOL sunucu', DATA.osEol.count], ['Disk %85+', DATA.critical.diskFull], []];
        rows.push(['OS sürümü','Adet']); (DATA.osVersion||[]).forEach(o=> rows.push([o.name, o.value]));
        rows.push([]); rows.push(['Etiket','Adet']); (DATA.tags||[]).forEach(o=> rows.push([o.name, o.value]));
        const csv = rows.map(r => r.map(c => '"' + String(c==null?'':c).replace(/"/g,'""') + '"').join(';')).join('\r\n');
        const blob = new Blob(['﻿'+csv], { type:'text/csv;charset=utf-8' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'vmon-istatistik-' + new Date().toISOString().slice(0,10) + '.csv';
        a.click();
    }

    grid.on('resizestop', (e,el)=>{ setTimeout(()=>{ renderWidget(el); }, 50); });
    window.addEventListener('resize', ()=> setTimeout(resizeAll,100));

    document.getElementById('btnRefresh').addEventListener('click', load);
    document.getElementById('btnExport').addEventListener('click', exportCsv);
    document.getElementById('btnFull').addEventListener('click', () => {
        if (!document.fullscreenElement) document.documentElement.requestFullscreen().catch(()=>{});
        else document.exitFullscreen();
    });
    document.addEventListener('fullscreenchange', () => setTimeout(resizeAll, 200));

    window.removeWidget = function(btn){
        const item = btn.closest('.grid-stack-item');
        const id = ensureId(item.querySelector('.stat-chart')||item);
        if (charts[id]) { charts[id].dispose(); delete charts[id]; }
        grid.removeWidget(item);
    };

    if (canEdit) {
        const editTools = document.getElementById('editTools');
        const btnEdit = document.getElementById('btnEdit');
        btnEdit.addEventListener('click', ()=>{
            editing = !editing;
            grid.enableMove(editing); grid.enableResize(editing);
            document.body.classList.toggle('stats-editing', editing);
            editTools.classList.toggle('hidden', !editing);
            btnEdit.innerHTML = editing ? '<i class="bi bi-unlock-fill"></i> <span>Kilitle</span>'
                                        : '<i class="bi bi-lock-fill"></i> <span>Düzenle</span>';
        });

        document.getElementById('btnAdd').addEventListener('click', ()=>{
            const [type, source] = document.getElementById('addType').value.split('|');
            const SIZE = { counter:[3,2], resource:[4,3], pie:[4,4], gauge:[4,3],
                fleet:[12,4], top:[6,5], critical:[6,2], uptime:[6,3], histogram:[6,4],
                capacity:[6,4], outage:[6,4], os_eol:[3,4], heatmap:[12,5] };
            const [w, h] = SIZE[type] || [4,3];
            const el = document.createElement('div');
            el.className = 'grid-stack-item';
            el.setAttribute('data-type', type); el.setAttribute('data-source', source); el.setAttribute('data-config','');
            el.innerHTML = '<div class="grid-stack-item-content"><div class="stat-card">'+
                '<button class="wremove btn btn-danger btn-sm" type="button" onclick="removeWidget(this)"><i class="bi bi-x-lg"></i></button>'+
                '<div class="widget-body" style="flex:1;display:flex;flex-direction:column;min-height:0;"></div></div></div>';
            grid.addWidget(el, { w, h, autoPosition:true });
            renderWidget(el);
        });

        document.getElementById('btnReset').addEventListener('click', async ()=>{
            if (!confirm('Tüm istatistik widget\'ları varsayılan düzene sıfırlanacak. Devam edilsin mi?')) return;
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const r = await fetch('@Url.Action("ResetLayout")', { method:'POST', headers:{ 'RequestVerificationToken': token } });
            if (r.ok) location.reload(); else alert('Sıfırlanamadı.');
        });

        document.getElementById('btnSave').addEventListener('click', async ()=>{
            const items = [];
            document.querySelectorAll('.grid-stack-item').forEach(it=>{
                const n = it.gridstackNode || {};
                items.push({
                    id: parseInt(it.getAttribute('data-id')||'0',10) || 0,
                    type: it.getAttribute('data-type'), source: it.getAttribute('data-source'),
                    title: null, configJson: it.getAttribute('data-config')||null,
                    x: n.x||0, y: n.y||0, w: n.w||3, h: n.h||2
                });
            });
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const r = await fetch('@Url.Action("SaveLayout")', {
                method:'POST',
                headers:{ 'Content-Type':'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify(items)
            });
            if (r.ok) { location.reload(); } else { alert('Kaydedilemedi.'); }
        });
    }

    let detailState = { source:null, value:null };
    const rangeLabel = { 7:'7 gün', 30:'1 ay', 90:'3 ay', 180:'6 ay', 365:'1 yıl' };
    const PIE_SOURCES = ['os_kind','os_version','tag'];

    // 1. seviye: kategori dökümü — sayısal bar listesi (örn. 95 Windows / 144 Linux)
    window.openBreakdown = function(source){
        detailState = { source, value:null };
        const meta = META[source] || { label: source };
        document.querySelector('#smTitle span').textContent = meta.label || source;
        document.getElementById('smTrend').classList.add('hidden');
        document.getElementById('smRange').classList.add('hidden');
        if (modalChart) { modalChart.dispose(); modalChart = null; }

        let arr = source==='os_kind' ? DATA?.osKind : source==='os_version' ? DATA?.osVersion : DATA?.tags;
        arr = (arr || []).slice();
        const total = arr.reduce((a,b)=>a+b.value, 0);
        const max = Math.max(1, ...arr.map(x=>x.value));
        const list = arr.length ? arr.map((d,i)=>{
            const w = Math.round(100*d.value/max), col = PALETTE[i%PALETTE.length];
            return '<button class="brk-row" data-name="'+esc(d.name)+'">'
                + '<span class="brk-name" title="'+esc(d.name)+'">'+esc(d.name)+'</span>'
                + '<span class="brk-bar"><span style="width:0%;background:'+col+'" data-w="'+w+'"></span></span>'
                + '<span class="brk-val">'+d.value+'</span></button>';
        }).join('') : '<div class="stat-sub">Veri yok.</div>';

        document.getElementById('smTableWrap').innerHTML =
            '<div class="stat-sub mb-2">Toplam <b>'+total+'</b> — bir kategoriye tıklayıp sunucuları görün.</div>'
            + '<div class="brk-list">'+list+'</div>';
        document.querySelectorAll('#smTableWrap .brk-row').forEach(b =>
            b.addEventListener('click', () => openDetail(source, b.dataset.name)));
        requestAnimationFrame(()=> document.querySelectorAll('#smTableWrap .brk-bar>span').forEach(s => s.style.width = s.dataset.w+'%'));
        document.getElementById('smodal').classList.add('open');
    };

    window.openDetail = async function(source, value){
        detailState = { source, value };
        const meta = META[source] || { label: source };
        document.querySelector('#smTitle span').textContent = (meta.label || source) + (value ? ' — ' + value : '');
        document.getElementById('smTableWrap').innerHTML = '<div class="stat-sub">Yükleniyor…</div>';
        document.getElementById('smTrend').classList.add('hidden');
        document.getElementById('smRange').classList.add('hidden');
        if (modalChart) { modalChart.dispose(); modalChart = null; }
        document.getElementById('smodal').classList.add('open');
        await renderDetail(7, true);
    };

    async function renderDetail(days, withTable){
        let d;
        try {
            const u = '@Url.Action("Detail")?source=' + encodeURIComponent(detailState.source)
                + '&value=' + encodeURIComponent(detailState.value || '') + '&days=' + days;
            d = await (await fetch(u)).json();
        } catch (e) { document.getElementById('smTableWrap').innerHTML = '<div class="stat-sub">Veri alınamadı.</div>'; return; }

        if (withTable) {
            const rows = (d.servers||[]).map(s=>'<tr>'+
                '<td>'+esc(s.name)+'<div class="text-slate-400" style="font-size:.72rem">'+esc(s.target||'')+'</div></td>'+
                '<td>'+esc(s.os||'')+'</td><td>'+statusBadge(s.status)+'</td>'+
                '<td>'+pct(s.cpu)+'</td><td>'+pct(s.ram)+'</td><td>'+pct(s.disk)+'</td>'+
                '<td class="text-slate-400">'+esc(s.capacity||'')+'</td></tr>').join('');
            const back = (PIE_SOURCES.includes(detailState.source) && detailState.value)
                ? '<button id="smBack" class="btn btn-outline btn-sm mb-3"><i class="bi bi-arrow-left"></i> Kategorilere dön</button>' : '';
            document.getElementById('smTableWrap').innerHTML = back +
                '<table class="stbl"><thead><tr><th>Sunucu</th><th>İşletim Sistemi</th><th>Durum</th><th>CPU</th><th>RAM</th><th>Disk</th><th>Kapasite</th></tr></thead><tbody>'
                + (rows || '<tr><td colspan="7" class="stat-sub">Kayıt yok.</td></tr>') + '</tbody></table>'
                + '<div class="stat-sub mt-2">Toplam ' + (d.count||0) + ' sunucu.</div>';
            const bb = document.getElementById('smBack');
            if (bb) bb.addEventListener('click', () => openBreakdown(detailState.source));
        }

        const trendDiv = document.getElementById('smTrend');
        const rangeBar = document.getElementById('smRange');
        if (d.trend && d.trend.points && d.trend.points.length) {
            rangeBar.classList.remove('hidden');
            trendDiv.classList.remove('hidden');
            rangeBar.querySelectorAll('.sm-range').forEach(b => {
                const on = parseInt(b.dataset.days,10) === (d.trend.days || days);
                b.classList.toggle('btn-primary', on); b.classList.toggle('btn-outline', !on);
            });
            if (modalChart) modalChart.dispose();
            modalChart = echarts.init(trendDiv);
            const mlabel = ({cpu:'CPU %', ram:'RAM %', disk:'Disk %'})[d.trend.metric] || '';
            modalChart.setOption({
                title:{ text:(rangeLabel[d.trend.days]||'') + ' — ' + mlabel, left:'center', textStyle:{fontSize:12,color:txtColor()} },
                tooltip:{ trigger:'axis' }, grid:{ left:42, right:18, top:36, bottom:28 },
                xAxis:{ type:'category', data:d.trend.points.map(p=>p.day), axisLabel:{color:txtColor()} },
                yAxis:{ type:'value', max:100, axisLabel:{color:txtColor()}, splitLine:{lineStyle:{color:trackColor()}} },
                series:[{ type:'line', smooth:true, areaStyle:{opacity:.15}, data:d.trend.points.map(p=>p.value),
                          itemStyle:{color:'#ed1c24'}, lineStyle:{color:'#ed1c24'} }]
            });
        } else {
            rangeBar.classList.add('hidden');
            trendDiv.classList.add('hidden');
            if (modalChart) { modalChart.dispose(); modalChart = null; }
        }
    }

    document.querySelectorAll('#smRange .sm-range').forEach(b => {
        b.addEventListener('click', () => renderDetail(parseInt(b.dataset.days,10), false));
    });
    window.closeDetail = function(){
        document.getElementById('smodal').classList.remove('open');
        if (modalChart) { modalChart.dispose(); modalChart = null; }
    };
    document.getElementById('smodal').addEventListener('click', e => { if (e.target.id === 'smodal') closeDetail(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeDetail(); });

    load();
    setInterval(load, 60000); // 1 dk'da bir tazele
})();
</script>

@model List<Credential>
@{
    ViewData["Title"] = "Kimlik Bilgileri";
    var usage = (Dictionary<int, int>)ViewBag.Usage;
}

<div class="flex flex-wrap items-center justify-between gap-3 mb-5">
    <div>
        <h1 class="text-2xl font-bold text-slate-800 flex items-center gap-2"><i class="bi bi-key text-brand-500"></i> Kimlik Bilgileri</h1>
        <p class="text-sm text-slate-500 mt-0.5">İzleme hesapları — manuel veya HashiCorp Vault</p>
    </div>
    <a class="btn btn-primary btn-sm" asp-action="Create"><i class="bi bi-plus-lg"></i> Yeni Kimlik</a>
</div>

<div class="alert-info text-sm mb-5">
    <i class="bi bi-shield-lock"></i> Manuel şifreler ve Vault token'ları Windows DPAPI ile şifrelenerek saklanır ve
    yalnızca bu sunucuda çözülebilir. Vault kaynaklı kimliklerde şifre uygulamada saklanmaz, kontrol anında Vault'tan çekilir.
</div>

<div class="card">
    <div class="overflow-x-auto">
        <table class="tbl">
            <thead>
                <tr><th>Ad</th><th>Kullanıcı</th><th>Domain</th><th>Kaynak</th><th>Açıklama</th><th>Kullanım</th><th></th></tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="7" class="text-center text-slate-400 py-6">Henüz kimlik bilgisi yok.</td></tr>
            }
            @foreach (var c in Model)
            {
                <tr>
                    <td><span class="font-semibold text-slate-800">@c.Name</span></td>
                    <td class="mono">
                        @if (c.SourceType == CredentialSource.Vault) { <span class="text-slate-400 italic">Vault → @c.VaultUserKey</span> }
                        else { @c.Username }
                    </td>
                    <td>@(c.Domain ?? "-")</td>
                    <td class="whitespace-nowrap">
                        @if (c.SourceType == CredentialSource.Vault)
                        {
                            <span class="badge pill-slow"><i class="bi bi-safe"></i> Vault</span>
                            <button type="button" class="btn btn-outline btn-sm ml-1" onclick="testVault(@c.Id, this)" title="Vault bağlantısını test et"><i class="bi bi-plug"></i></button>
                        }
                        else { <span class="badge pill-muted">Manuel</span> }
                    </td>
                    <td class="text-sm text-slate-400">@c.Description</td>
                    <td>
                        @if (usage.TryGetValue(c.Id, out var n)) { <span class="badge pill-info">@n servis</span> }
                        else { <span class="text-slate-400">-</span> }
                    </td>
                    <td class="text-right whitespace-nowrap">
                        <a class="btn btn-outline btn-sm" asp-action="Edit" asp-route-id="@c.Id"><i class="bi bi-pencil"></i></a>
                        <form method="post" asp-action="Delete" asp-route-id="@c.Id" class="inline" onsubmit="return confirm('@c.Name silinsin mi?');">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
async function testVault(id, btn) {
    const original = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="bi bi-arrow-repeat animate-spin"></i>';
    try {
        const resp = await fetch(`/api/vault-test/${id}`, { method: "POST" });
        const data = await resp.json();
        alert(data.ok ? "✅ " + data.message : "❌ " + data.message);
    } catch (e) { alert("❌ Test başarısız: " + e.message); }
    finally { btn.disabled = false; btn.innerHTML = original; }
}
</script>
}

@model Credential
@{
    ViewData["Title"] = Model.Id == 0 ? "Yeni Kimlik Bilgisi" : "Kimlik Bilgisi Düzenle";
}

<h1 class="text-2xl font-bold text-slate-800 flex items-center gap-2 mb-5"><i class="bi bi-key text-brand-500"></i> @ViewData["Title"]</h1>

<div class="card max-w-2xl">
    <div class="card-body">
        <form method="post" asp-action="Save" autocomplete="off" class="space-y-4">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="All" class="text-rose-600 text-sm"></div>

            <div>
                <label class="label">Tanım Adı *</label>
                <input asp-for="Name" class="input" placeholder="örn. Oracle ReadOnly İzleme Hesabı" />
            </div>
            <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
                <div class="md:col-span-7" id="usernameCol">
                    <label class="label">Kullanıcı Adı *</label>
                    <input asp-for="Username" class="input mono" placeholder="monitor_ro / user@domain / CN=...,DC=..." />
                    <div class="hint">LDAP için DOMAIN hesabı veya tam DN; DB için DB kullanıcısı.</div>
                </div>
                <div class="md:col-span-5">
                    <label class="label">Domain</label>
                    <input asp-for="Domain" class="input" placeholder="FIRMA (AD/DHCP için)" />
                    <div class="hint hidden" id="domainVaultHint">Vault kimliğinde de gerekiyorsa doldurun (AD/DHCP).</div>
                </div>
            </div>

            <div>
                <label class="label">Şifre Kaynağı</label>
                <div class="inline-flex rounded-xl border border-slate-200 overflow-hidden">
                    <input type="radio" class="hidden" asp-for="SourceType" value="@CredentialSource.Manual" id="srcManual" />
                    <label class="px-4 py-2 text-sm font-medium cursor-pointer" id="lblManual" for="srcManual"><i class="bi bi-keyboard"></i> Manuel Şifre</label>
                    <input type="radio" class="hidden" asp-for="SourceType" value="@CredentialSource.Vault" id="srcVault" />
                    <label class="px-4 py-2 text-sm font-medium cursor-pointer border-l border-slate-200" id="lblVault" for="srcVault"><i class="bi bi-safe"></i> HashiCorp Vault</label>
                </div>
            </div>

            <div id="manualSection">
                <label class="label">Şifre @(Model.Id == 0 ? "*" : "")</label>
                <input type="password" name="newPassword" class="input" autocomplete="new-password"
                       placeholder="@(Model.Id == 0 ? "" : "Değiştirmek istemiyorsanız boş bırakın")" />
            </div>

            <div id="vaultSection" class="hidden">
                <div class="bg-slate-50 rounded-xl border border-slate-200 p-4 space-y-4">
                    <div>
                        <label class="label">Vault Secret URL *</label>
                        <input asp-for="VaultUrl" class="input mono" placeholder="vault-prod.firma.com.tr/v1/vmon/data/secrets" />
                        <div class="hint">KV v2 için path'te <code>/data/</code> segmenti bulunmalı. https:// öneki otomatik eklenir.</div>
                    </div>
                    <div>
                        <label class="label">Vault Token @(Model.Id == 0 ? "*" : "")</label>
                        <input type="password" name="newVaultToken" class="input mono" autocomplete="new-password"
                               placeholder="@(Model.Id == 0 ? "hvs...." : "Değiştirmek istemiyorsanız boş bırakın")" />
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="label">Kullanıcı Adı Anahtarı *</label>
                            <input asp-for="VaultUserKey" class="input mono" placeholder="örn. username" />
                            <div class="hint">Secret JSON'ında kullanıcı adını tutan alan.</div>
                        </div>
                        <div>
                            <label class="label">Şifre Anahtarı *</label>
                            <input asp-for="VaultKey" class="input mono" placeholder="örn. password" />
                            <div class="hint">Secret JSON'ında şifreyi tutan alan.</div>
                        </div>
                    </div>
                    <div class="text-xs text-slate-500">
                        <i class="bi bi-shield-lock"></i> Kullanıcı adı ve şifre, kontrol anında secret'tan birlikte çekilir.
                        Token, manuel şifrelerle aynı mekanizmayla (DPAPI, LocalMachine) şifrelenerek saklanır.
                        Çekilen bilgiler diske yazılmaz; yalnızca bellekte kullanılır ve 5 dakika önbellekte tutulur.
                    </div>
                </div>
            </div>

            <div>
                <label class="label">Açıklama</label>
                <input asp-for="Description" class="input" />
            </div>

            <div class="flex gap-2">
                <button class="btn btn-primary"><i class="bi bi-save"></i> Kaydet</button>
                <a class="btn btn-outline" asp-action="Index">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function toggleSource() {
    const isVault = document.getElementById("srcVault").checked;
    document.getElementById("manualSection").classList.toggle("hidden", isVault);
    document.getElementById("vaultSection").classList.toggle("hidden", !isVault);
    document.getElementById("usernameCol").classList.toggle("hidden", isVault);
    document.getElementById("domainVaultHint").classList.toggle("hidden", !isVault);
    // Segment aktif görünümü
    const on = "bg-brand-500 text-white", off = "text-slate-600 hover:bg-slate-50";
    document.getElementById("lblManual").className = "px-4 py-2 text-sm font-medium cursor-pointer " + (isVault ? off : on);
    document.getElementById("lblVault").className = "px-4 py-2 text-sm font-medium cursor-pointer border-l border-slate-200 " + (isVault ? on : off);
}
document.getElementById("srcManual").addEventListener("change", toggleSource);
document.getElementById("srcVault").addEventListener("change", toggleSource);
toggleSource();
</script>
}

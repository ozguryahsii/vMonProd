@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@inject vMonitor.Services.SettingsService Settings
@{
    var __csrf = Antiforgery.GetAndStoreTokens(Context);
    bool mutEnabled = false;
    try { mutEnabled = (await Settings.GetAsync()).MutabakatEnabled; } catch { }
    var __theme = Context.Request.Cookies["vmon_theme"] == "dark" ? "dark" : "";
    var __lang = Context.Request.Cookies["vmon_lang"] == "en" ? "en" : "tr";
}
<!DOCTYPE html>
<html lang="@__lang" class="@__theme">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="csrf-token" content="@__csrf.RequestToken" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — " : "")vMon</title>
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" asp-append-version="true" />
    <script src="~/lib/tailwind/tailwind.js" asp-append-version="true"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        brand: { 50:'#fef2f2',100:'#fee2e2',200:'#fecaca',300:'#fca5a5',400:'#f87171',500:'#ed1c24',600:'#d4151c',700:'#a30f15',800:'#7f1d1d' }
                    },
                    fontFamily: { sans: ['ui-sans-serif','system-ui','Segoe UI','Roboto','Helvetica Neue','Arial','sans-serif'] }
                }
            }
        };
    </script>
    <style type="text/tailwindcss">
        @@layer components {
            .card { @@apply bg-white rounded-2xl border border-slate-200/80 shadow-sm; }
            .card-head { @@apply px-5 py-3.5 border-b border-slate-100 flex items-center justify-between gap-3 font-semibold text-slate-700; }
            .card-body { @@apply p-5; }

            .btn { @@apply inline-flex items-center justify-center gap-2 px-4 py-2 rounded-xl text-sm font-medium transition-all duration-150 active:scale-95 focus:outline-none focus:ring-2 focus:ring-brand-100 disabled:opacity-50 disabled:pointer-events-none; }
            .btn-sm { @@apply px-3 py-1.5 text-xs rounded-lg; }
            .btn-primary { @@apply bg-brand-500 text-white hover:bg-brand-600 shadow-sm shadow-brand-500/20; }
            .btn-outline { @@apply border border-slate-300 text-slate-700 bg-white hover:bg-slate-50; }
            .btn-danger { @@apply bg-rose-500 text-white hover:bg-rose-600; }
            .btn-success { @@apply bg-emerald-500 text-white hover:bg-emerald-600; }
            .btn-ghost { @@apply text-slate-600 hover:bg-slate-100; }

            .input { @@apply w-full rounded-xl border border-slate-300 px-3 py-2 text-sm text-slate-800 bg-white placeholder-slate-400 focus:border-brand-400 focus:ring-2 focus:ring-brand-100 outline-none transition; }
            .label { @@apply block text-sm font-medium text-slate-600 mb-1.5; }
            .hint { @@apply text-xs text-slate-400 mt-1; }
            .switch { @@apply h-5 w-5 rounded border-slate-300 text-brand-500 focus:ring-brand-200; }

            .badge { @@apply inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-xs font-semibold; }
            .pill-up { @@apply bg-emerald-100 text-emerald-700; }
            .pill-down { @@apply bg-rose-100 text-rose-700; }
            .pill-slow { @@apply bg-amber-100 text-amber-700; }
            .pill-error { @@apply bg-orange-100 text-orange-700; }
            .pill-muted { @@apply bg-slate-100 text-slate-500; }
            .pill-info { @@apply bg-sky-100 text-sky-700; }
            .pill-type { @@apply bg-slate-100 text-slate-600 border border-slate-200; }

            .stat { @@apply card flex flex-col items-center justify-center py-4 text-center transition-all duration-150; }
            .stat-btn { @@apply hover:-translate-y-0.5 hover:shadow-md active:scale-[0.98]; }
            .stat-num { @@apply text-3xl font-bold tabular-nums; }
            .stat-label { @@apply text-xs uppercase tracking-wide text-slate-400 mt-0.5; }

            .tbl { @@apply w-full text-sm; }
            .tbl thead th { @@apply text-left text-[11px] font-semibold uppercase tracking-wider text-slate-400 px-4 py-3 border-b border-slate-100 bg-slate-50/50; }
            .tbl tbody td { @@apply px-4 py-3 border-b border-slate-50 text-slate-700 align-middle; }
            .tbl tbody tr { @@apply transition; }
            .tbl tbody tr:hover { @@apply bg-slate-50; }

            .mono { @@apply font-mono text-[0.78rem]; }
            .muted { @@apply text-slate-400; }

            .alert-ok { @@apply bg-emerald-50 text-emerald-800 border border-emerald-200 rounded-xl px-4 py-3 flex items-center gap-2; }
            .alert-err { @@apply bg-rose-50 text-rose-800 border border-rose-200 rounded-xl px-4 py-3 flex items-center gap-2; }
            .alert-info { @@apply bg-sky-50 text-sky-800 border border-sky-200 rounded-xl px-4 py-3; }
            .alert-warn { @@apply bg-amber-50 text-amber-900 border border-amber-200 rounded-xl px-4 py-3; }

            .status-card { @@apply card border-l-4 border-l-slate-300 transition-all duration-150 hover:shadow-lg hover:-translate-y-0.5; }
            .status-card.up { @@apply border-l-emerald-500; }
            .status-card.down { @@apply border-l-rose-500; }
            .status-card.slow { @@apply border-l-amber-400; }
            .status-card.error { @@apply border-l-orange-500; }
            .status-card.disabled { @@apply border-l-slate-300 opacity-60; }

            .navlink { @@apply flex items-center gap-2 px-3 py-2 rounded-xl text-sm font-medium text-slate-300 hover:text-white hover:bg-white/10 transition whitespace-nowrap; }
            .modal-card { @@apply bg-white rounded-2xl shadow-2xl w-full max-w-3xl; }
        }
    </style>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="font-sans text-slate-800 antialiased">
    <nav class="bg-gradient-to-r from-slate-900 via-slate-800 to-slate-900 shadow-lg sticky top-0 z-40" x-data="{ open:false }">
        <div class="px-4 lg:px-6">
            <div class="flex items-center h-16 gap-2">
                <a class="flex items-center gap-2 text-white font-bold text-lg mr-2" asp-controller="Home" asp-action="Index">
                    <span class="logo-box inline-flex items-center justify-center h-9 w-9 rounded-xl bg-brand-500 shadow-md shadow-brand-500/30">
                        <i class="bi bi-activity text-white text-lg logo-anim"></i>
                    </span>
                    <span>vMon</span>
                </a>

                <button class="ml-auto lg:hidden text-slate-200 p-2" @@click="open = !open"><i class="bi bi-list text-2xl"></i></button>

                <div class="hidden lg:flex items-center gap-1">
                    @if (User.Can(Perms.DashboardsView)) {
                        <a class="navlink" asp-controller="Dashboards" asp-action="Index"><i class="bi bi-columns-gap"></i> Dashboard'lar</a>
                        <a class="navlink" asp-controller="Reports" asp-action="Index"><i class="bi bi-bar-chart-line"></i> Raporlar</a>
                        <a class="navlink" asp-controller="Statistics" asp-action="Index"><i class="bi bi-graph-up-arrow"></i> İstatistikler</a>
                    }
                    @if (User.Can(Perms.ServicesManage)) {
                        <a class="navlink" asp-controller="Services" asp-action="Index"><i class="bi bi-hdd-network"></i> Servisler</a>
                    }
                    @if (User.Can(Perms.CredentialsManage)) {
                        <a class="navlink" asp-controller="Credentials" asp-action="Index"><i class="bi bi-key"></i> Kimlik Bilgileri</a>
                    }
                    @if (User.IsAppAdmin())
                    {
                        <a class="navlink" asp-controller="Settings" asp-action="Index"><i class="bi bi-gear"></i> Ayarlar</a>
                        <a class="navlink" asp-controller="Users" asp-action="Index"><i class="bi bi-people"></i> Kullanıcılar</a>
                        <a class="navlink" asp-controller="Audit" asp-action="Index"><i class="bi bi-clipboard-check"></i> Denetim</a>
                    }
                    @if (mutEnabled && User.Can(Perms.MutabakatView)) {
                        <a class="navlink" asp-controller="Mutabakat" asp-action="Index"><i class="bi bi-clipboard-data"></i> Mutabakat</a>
                    }
                    <a class="navlink" asp-controller="Home" asp-action="About"><i class="bi bi-info-circle"></i> Hakkında</a>
                </div>

                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <div class="hidden lg:flex items-center gap-3 ml-auto">
                        <div class="relative" x-data="{open:false}">
                            <button type="button" @@click="open=!open" class="text-white text-sm font-medium inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg hover:bg-white/10 transition">
                                <i class="bi bi-person-circle text-base"></i> @User.Identity.Name <i class="bi bi-chevron-down text-[10px]"></i>
                            </button>
                            <div x-show="open" @@click.outside="open=false" x-cloak
                                 class="absolute right-0 mt-1 w-52 bg-white rounded-xl shadow-xl border border-slate-200 p-2 z-50">
                                <div class="px-2 py-1 text-[11px] font-semibold uppercase tracking-wide text-slate-400">Tema</div>
                                <button type="button" class="theme-opt w-full flex items-center gap-2 px-2 py-1.5 rounded-lg hover:bg-slate-100 text-sm text-slate-700" data-theme="light">
                                    <span class="inline-block w-3.5 h-3.5 rounded-full border border-slate-300" style="background:#f1f5f9"></span> Açık
                                    <i class="bi bi-check2 ml-auto text-brand-500 theme-check" data-for="light"></i>
                                </button>
                                <button type="button" class="theme-opt w-full flex items-center gap-2 px-2 py-1.5 rounded-lg hover:bg-slate-100 text-sm text-slate-700" data-theme="dark">
                                    <span class="inline-block w-3.5 h-3.5 rounded-full border border-slate-600" style="background:#0f172a"></span> Koyu
                                    <i class="bi bi-check2 ml-auto text-brand-500 theme-check" data-for="dark"></i>
                                </button>
                                <div class="border-t border-slate-100 my-1.5"></div>
                                <div class="px-2 py-1 text-[11px] font-semibold uppercase tracking-wide text-slate-400">Dil</div>
                                <button type="button" class="lang-opt w-full flex items-center gap-2 px-2 py-1.5 rounded-lg hover:bg-slate-100 text-sm text-slate-700" data-lang="tr">
                                    <span class="text-base leading-none">🇹🇷</span> Türkçe
                                    <i class="bi bi-check2 ml-auto text-brand-500 lang-check" data-for="tr"></i>
                                </button>
                                <button type="button" class="lang-opt w-full flex items-center gap-2 px-2 py-1.5 rounded-lg hover:bg-slate-100 text-sm text-slate-700" data-lang="en">
                                    <span class="text-base leading-none">🇬🇧</span> English
                                    <i class="bi bi-check2 ml-auto text-brand-500 lang-check" data-for="en"></i>
                                </button>
                                <div class="border-t border-slate-100 my-1.5"></div>
                                <a href="@Url.Action("Profile","Account")" class="w-full flex items-center gap-2 px-2 py-1.5 rounded-lg hover:bg-slate-100 text-sm text-slate-700"><i class="bi bi-person-badge"></i> Profilim</a>
                                <form method="post" asp-controller="Account" asp-action="Logout">
                                    @Html.AntiForgeryToken()
                                    <button class="w-full flex items-center gap-2 px-2 py-1.5 rounded-lg hover:bg-rose-50 text-rose-600 text-sm font-medium"><i class="bi bi-box-arrow-right"></i> Çıkış</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Mobil menü -->
            <div class="lg:hidden pb-3 flex flex-col gap-1" x-show="open" x-cloak>
                @if (User.Can(Perms.DashboardsView)) {
                    <a class="navlink" asp-controller="Dashboards" asp-action="Index"><i class="bi bi-columns-gap"></i> Dashboard'lar</a>
                    <a class="navlink" asp-controller="Reports" asp-action="Index"><i class="bi bi-bar-chart-line"></i> Raporlar</a>
                    <a class="navlink" asp-controller="Statistics" asp-action="Index"><i class="bi bi-graph-up-arrow"></i> İstatistikler</a>
                }
                @if (User.Can(Perms.ServicesManage)) { <a class="navlink" asp-controller="Services" asp-action="Index"><i class="bi bi-hdd-network"></i> Servisler</a> }
                @if (User.Can(Perms.CredentialsManage)) { <a class="navlink" asp-controller="Credentials" asp-action="Index"><i class="bi bi-key"></i> Kimlik Bilgileri</a> }
                @if (User.IsAppAdmin())
                {
                    <a class="navlink" asp-controller="Settings" asp-action="Index"><i class="bi bi-gear"></i> Ayarlar</a>
                    <a class="navlink" asp-controller="Users" asp-action="Index"><i class="bi bi-people"></i> Kullanıcılar</a>
                    <a class="navlink" asp-controller="Audit" asp-action="Index"><i class="bi bi-clipboard-check"></i> Denetim</a>
                }
                @if (mutEnabled && User.Can(Perms.MutabakatView)) {
                    <a class="navlink" asp-controller="Mutabakat" asp-action="Index"><i class="bi bi-clipboard-data"></i> Mutabakat</a>
                }
                <a class="navlink" asp-controller="Home" asp-action="About"><i class="bi bi-info-circle"></i> Hakkında</a>
                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <form method="post" asp-controller="Account" asp-action="Logout" class="px-3 pt-2">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline w-full"><i class="bi bi-box-arrow-right"></i> Çıkış (@User.Identity.Name)</button>
                    </form>
                }
            </div>
        </div>
    </nav>

    <main class="max-w-[1600px] mx-auto px-4 lg:px-6 py-6">
        @if (TempData["Message"] != null)
        {
            <div class="alert-ok mb-4 fade-in" x-data="{s:true}" x-show="s">
                <i class="bi bi-check-circle-fill"></i> <span class="flex-1">@TempData["Message"]</span>
                <button type="button" @@click="s=false" class="text-emerald-700/60 hover:text-emerald-900"><i class="bi bi-x-lg"></i></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert-err mb-4 fade-in" x-data="{s:true}" x-show="s">
                <i class="bi bi-exclamation-triangle-fill"></i> <span class="flex-1">@TempData["Error"]</span>
                <button type="button" @@click="s=false" class="text-rose-700/60 hover:text-rose-900"><i class="bi bi-x-lg"></i></button>
            </div>
        }
        @RenderBody()
    </main>

    <script>
        window.vPerms = {
            check: @(User.Can(Perms.ServicesCheck) ? "true" : "false"),
            control: @(User.Can(Perms.ServicesControl) ? "true" : "false"),
            manage: @(User.Can(Perms.ServicesManage) ? "true" : "false")
        };
    </script>
    @if (User?.Identity?.IsAuthenticated == true)
    {
        <form method="post" asp-controller="Account" asp-action="Logout" id="idleLogoutForm" class="hidden">
            @Html.AntiForgeryToken()
        </form>
        <script>
            // Boşta oturum oto-kapatma (PCI DSS 8.2.8: 15 dk hareketsizlik)
            (function () {
                var IDLE_MS = 15 * 60 * 1000, t;
                function reset() { clearTimeout(t); t = setTimeout(function () {
                    try { document.getElementById('idleLogoutForm').submit(); }
                    catch (e) { location.href = '/Account/Login'; }
                }, IDLE_MS); }
                ['mousemove','keydown','click','scroll','touchstart'].forEach(function (ev) {
                    window.addEventListener(ev, reset, { passive: true });
                });
                reset();
            })();
        </script>
    }
    <script src="~/lib/alpine/alpine.min.js" asp-append-version="true" defer></script>
    <script src="~/js/ui.js" asp-append-version="true"></script>
    <script src="~/js/i18n.js" asp-append-version="true"></script>
    <script>
        // Tema + dil tercihi: çerez (sunucu okur, yanıp sönme yok) + DB (/Account/SetPreference) + sayfa yenile
        (function () {
            function setCookie(k, v) { document.cookie = k + "=" + v + ";path=/;max-age=31536000;samesite=lax"; }
            function markTheme() {
                var t = document.documentElement.classList.contains("dark") ? "dark" : "light";
                document.querySelectorAll(".theme-check").forEach(function (c) { c.style.visibility = (c.dataset.for === t) ? "visible" : "hidden"; });
            }
            function markLang() {
                var l = document.documentElement.lang === "en" ? "en" : "tr";
                document.querySelectorAll(".lang-check").forEach(function (c) { c.style.visibility = (c.dataset.for === l) ? "visible" : "hidden"; });
            }
            function save(params) {
                // Kaydı dene; başarılı/başarısız fark etmeksizin çerez yazıldığı için yeniden yükle
                try { return fetch("/Account/SetPreference", { method: "POST", body: new URLSearchParams(params) }); }
                catch (e) { return Promise.resolve(); }
            }
            document.querySelectorAll(".theme-opt").forEach(function (b) {
                b.addEventListener("click", function () {
                    var t = b.dataset.theme;
                    if ((document.documentElement.classList.contains("dark") ? "dark" : "light") === t) return;
                    setCookie("vmon_theme", t);
                    save({ theme: t }).finally(function () { location.reload(); });
                });
            });
            document.querySelectorAll(".lang-opt").forEach(function (b) {
                b.addEventListener("click", function () {
                    var l = b.dataset.lang;
                    if ((document.documentElement.lang === "en" ? "en" : "tr") === l) return;
                    setCookie("vmon_lang", l);
                    save({ lang: l }).finally(function () { location.reload(); });
                });
            });
            markTheme(); markLang();
        })();
    </script>
    <style>[x-cloak]{display:none !important;}</style>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

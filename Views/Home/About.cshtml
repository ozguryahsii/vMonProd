@inject vMonitor.Services.LicenseService Lic
@{
    ViewData["Title"] = "Hakkında";
    // Dil çerezine göre sunucu-taraflı iki dillilik (About baştan sona seçilen dilde gösterilir)
    var en = Context.Request.Cookies["vmon_lang"] == "en";
    string T(string tr, string eng) => en ? eng : tr;
    // React /app/about içine gömülü görünüm: üst menü gizlenir, zemin şeffaf (tek içerik kaynağı)
    var embed = Context.Request.Query["embed"] == "1";
}
@if (embed)
{
    <style>
        nav.vnav { display: none !important; }
        body { background: transparent !important; }
        main { padding-top: 0 !important; }
    </style>
}

<div class="max-w-4xl mx-auto">
    <div class="rounded-2xl bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white p-8 text-center mb-6 shadow-lg">
        <div class="logo-box inline-flex items-center justify-center h-14 w-14 rounded-2xl bg-brand-500 shadow-lg shadow-brand-500/40 mb-3">
            <i class="bi bi-activity text-2xl logo-anim"></i>
        </div>
        <h1 class="text-3xl font-bold">vMon</h1>
        <p class="text-slate-300 mt-1">@T("Servis İzleme ve Raporlama Platformu", "Service Monitoring & Reporting Platform")</p>
    </div>

    <div class="card mb-6">
        <div class="card-head"><i class="bi bi-info-circle text-brand-500"></i> @T("Genel Bilgiler", "General Information")</div>
        <div class="card-body space-y-4">
            <div class="flex gap-3">
                <div class="w-44 shrink-0 font-medium text-slate-600"><i class="bi bi-person-badge text-brand-500"></i> @T("Geliştiren", "Developed by")</div>
                <div class="text-slate-700">Özgür Adnan Yahşi</div>
            </div>
            <div class="flex gap-3">
                <div class="w-44 shrink-0 font-medium text-slate-600"><i class="bi bi-calendar3 text-brand-500"></i> @T("Yapım Tarihi", "Build Date")</div>
                <div class="text-slate-700">@T("Temmuz 2026", "July 2026")</div>
            </div>
            <div class="flex gap-3">
                <div class="w-44 shrink-0 font-medium text-slate-600"><i class="bi bi-key text-brand-500"></i> @T("Lisans", "License")</div>
                <div class="text-slate-700">
                    @if (Lic.Current is { } lic)
                    {
                        var warn = lic.DaysLeft <= 30;
                        <span class="badge pill-info">@lic.Edition</span>
                        <span class="ml-1">@lic.Company</span>
                        <span class="ml-1 text-slate-500">— @T("bitiş", "expires"): @lic.ExpiresAt.ToString("dd.MM.yyyy")</span>
                        <span class="ml-1 font-semibold @(warn ? "text-rose-600" : "text-emerald-600")">@lic.DaysLeft @T("gün kaldı", "days left")</span>
                        <div class="mt-1 text-xs text-slate-500">@T("Makine Kodu", "Machine Code"): <code class="font-semibold">@vMonitor.Services.LicenseService.MachineCode</code> — @T("yenileme key'i isterken bu kodu iletin.", "send this code when requesting a renewal key.")</div>
                        @if (warn)
                        {
                            <div class="mt-1 text-xs text-rose-600">@T("Lisanslar yıllık yenilenir — süre dolunca uygulama yeni key girilene kadar kilitlenir.", "Licenses renew yearly — when it expires the application locks until a new key is entered.")</div>
                        }
                    }
                    else
                    {
                        <span class="font-semibold text-rose-600">@T("Lisans tanımlı değil", "No license defined")</span>
                    }
                </div>
            </div>
            <div class="flex gap-3" x-data="{ open:false }">
                <div class="w-44 shrink-0 font-medium text-slate-600"><i class="bi bi-tag text-brand-500"></i> @T("Versiyon", "Version")</div>
                <div class="text-slate-700 flex-1">
                    <button type="button" @@click="open=!open" class="inline-flex items-center gap-2 group">
                        <span class="badge pill-info">@vMonitor.Services.VersionInfo.AppVersion</span>
                        <span class="text-xs text-brand-600 group-hover:underline">@T("Sürüm notları", "Release notes") <i class="bi" :class="open ? 'bi-chevron-up' : 'bi-chevron-down'"></i></span>
                    </button>
                    @* SÜREÇ NOTU: Burada YALNIZ son sürümün notları durur (eski notlar tutulmaz).
                       Her yeni sürümde bu blok o sürümün TR+EN notlarıyla DEĞİŞTİRİLİR;
                       aynı notlar GitHub release body'sine de yazılır. *@
                    <div x-show="open" x-cloak class="mt-3 rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm leading-relaxed text-slate-600">
                        @if (en)
                        {
                            <p class="font-semibold text-slate-700 mb-2">Version 2.26.1 — Redesigned Settings page</p>
                            <ul class="list-disc ml-5 space-y-1.5">
                                <li><strong>Single-column Settings:</strong> every settings card is now full width in a single column — no more mixed card sizes or layout shifts. Fields spread across the row and adapt to narrow screens automatically.</li>
                                <li><strong>New order:</strong> cards are arranged top-down as Update, General, Login Logo, License, Email (SMTP), Notification Channels, Sign-in (LDAP/AD), Two-Step Verification (OTP), Local Password Policy, Global Monitoring Settings, SIEM/Syslog, Backup, Backups, Status Page, End-of-Life (EOL) and Reconciliation — the Update card sits at the very top.</li>
                                <li><strong>Renamed cards:</strong> "Security &amp; Compliance" is now <b>Local Password Policy</b>; "Monitoring" is now <b>Global Monitoring Settings</b>. All settings and functions are unchanged.</li>
                            </ul>
                        }
                        else
                        {
                            <p class="font-semibold text-slate-700 mb-2">Sürüm 2.26.1 — Yenilenen Ayarlar sayfası</p>
                            <ul class="list-disc ml-5 space-y-1.5">
                                <li><strong>Tek sütun Ayarlar:</strong> tüm ayar kartları artık tek sütunda tam genişlik — küçük/büyük kutu farkları ve kaymalar bitti. Alanlar satır boyunca yayılır, dar ekranda otomatik alt alta iner.</li>
                                <li><strong>Yeni sıralama:</strong> kartlar yukarıdan aşağı Güncelleme, Genel, Giriş Ekranı Logosu, Lisans, E-posta (SMTP), Bildirim Kanalları, Oturum Açma (LDAP/AD), İki Adımlı Doğrulama (OTP), Local Parola Politikası, Global İzleme Ayarları, SIEM/Syslog, Yedekleme, Yedekler, Durum Sayfası, Destek Sonu (EOL) ve Mutabakat düzenindedir — Güncelleme kartı en tepededir.</li>
                                <li><strong>Yeniden adlandırma:</strong> "Güvenlik ve Uyumluluk" artık <b>Local Parola Politikası</b>; "İzleme" artık <b>Global İzleme Ayarları</b>. Tüm ayarlar ve işlevler aynen korundu.</li>
                            </ul>
                        }
                    </div>
                </div>
            </div>
            <div class="flex gap-3">
                <div class="w-44 shrink-0 font-medium text-slate-600"><i class="bi bi-gear-wide-connected text-brand-500"></i> @T("Yetenekler", "Capabilities")</div>
                <div class="text-slate-700 leading-relaxed flex-1">
                    @if (en)
                    {
                        <ul class="list-disc ml-5 space-y-1.5">
                            <li><strong>Monitor types:</strong> HTTP/HTTPS, TCP port, ICMP ping, DNS, SFTP, SMTP &amp; IMAP (Exchange / Exchange Online), LDAP/LDAPS (Active Directory), DHCP, and Windows/Linux service status with remote start/stop/restart.</li>
                            <li><strong>Server health:</strong> real-time CPU / RAM / Disk monitoring on Windows and Linux, per-disk capacity &amp; usage detail, hardware capacity and exact OS version inventory, end-of-life (EOL) tracking via endoflife.date.</li>
                            <li><strong>Database monitoring:</strong> Oracle, SQL Server and MySQL — connectivity, clock drift, active/blocked sessions, long-running queries, tablespace/database status, connection usage and MySQL replication; clicking a metric opens a live detail list (who, which query).</li>
                            <li><strong>SSL certificate monitoring:</strong> dual external (via public DNS — as really seen from the internet) and internal checks, days-remaining tracking with a warning threshold, and internal/external certificate comparison that catches certificates renewed on the server but left stale on the F5/load balancer.</li>
                            <li><strong>Alarms &amp; notifications:</strong> email (authenticated SMTP: none/STARTTLS/SSL), SMS / WhatsApp / Voice-IVR via templated HTTP integrations (Twilio, NetGSM etc. without code), per-monitor channel switches, interactive WhatsApp buttons (start/stop/restart with permission mapping), recovery notifications, response-time and CPU/RAM/Disk thresholds.</li>
                            <li><strong>Self-Healing:</strong> after X consecutive down checks the service is automatically restarted up to Y times before an alarm is raised; every intervention is written to the audit log and the real outcome is shown on the monitor.</li>
                            <li><strong>Disk-full forecasting:</strong> least-squares trend on 30 days of disk history predicts which disks will fill within 90 days.</li>
                            <li><strong>Dashboards &amp; statistics:</strong> tabbed multi-dashboards with live charts, a DB health instance panel, a widget-based statistics board (fleet trend, capacity, top consumers, outage summary, usage histogram, CPU heatmap, approaching disk-full and certificate expirations…), fullscreen NOC mode, printable PDF management report, CSV export/import and bulk editing.</li>
                            <li><strong>Public status page:</strong> a no-login <code>/durum</code> page with live status and 90-day uptime strips for the monitors you choose to publish.</li>
                            <li><strong>Reporting:</strong> date-ranged availability reports going back up to 1 year, outage details, average/peak usage statistics.</li>
                            <li><strong>Enterprise:</strong> LDAP/AD sign-in + local users, granular role-based permissions, two-factor login (OTP via email/SMS/WhatsApp), hash-chained tamper-evident audit log, SIEM/syslog forwarding, scheduled &amp; encrypted backups, HashiCorp Vault integration, multiple databases (SQLite, SQL Server, MySQL, Oracle, PostgreSQL), first-run setup wizard, one-click self-update, bilingual UI (TR/EN) and dark theme.</li>
                        </ul>
                    }
                    else
                    {
                        <ul class="list-disc ml-5 space-y-1.5">
                            <li><strong>İzleme tipleri:</strong> HTTP/HTTPS, TCP port, ICMP ping, DNS, SFTP, SMTP &amp; IMAP (Exchange / Exchange Online), LDAP/LDAPS (Active Directory), DHCP ve uzaktan başlat/durdur/yeniden başlat destekli Windows/Linux servis durumu.</li>
                            <li><strong>Sunucu sağlığı:</strong> Windows ve Linux'ta gerçek zamanlı CPU / RAM / Disk izleme, disk başına kapasite ve doluluk detayı, donanım kapasitesi ve tam işletim sistemi sürümü envanteri, endoflife.date ile destek-sonu (EOL) takibi.</li>
                            <li><strong>Veritabanı izleme:</strong> Oracle, SQL Server ve MySQL — bağlantı, saat sapması, aktif/bloklu oturumlar, uzun süren sorgular, tablespace/veritabanı durumu, bağlantı doluluğu ve MySQL replikasyonu; metrik kutusuna tıklayınca canlı detay listesi açılır (kim, hangi sorgu).</li>
                            <li><strong>SSL sertifika izleme:</strong> dışarıdan (public DNS ile — internetten gerçekten göründüğü haliyle) ve içeriden çift kontrol, uyarı eşikli kalan gün takibi ve sunucuda yenilenip F5/yük dengeleyicide eski kalan sertifikayı yakalayan iç/dış karşılaştırma.</li>
                            <li><strong>Alarm ve bildirim:</strong> e-posta (kimlik doğrulamalı SMTP: yok/STARTTLS/SSL), şablonlu HTTP entegrasyonlarıyla SMS / WhatsApp / Sesli-IVR (Twilio, NetGSM vb. kod gerekmeden), izleme bazlı kanal seçimi, interaktif WhatsApp butonları (yetki eşlemeli başlat/durdur/yeniden başlat), düzelme bildirimi, yanıt süresi ve CPU/RAM/Disk eşikleri.</li>
                            <li><strong>Self-Healing:</strong> üst üste X down kontrolünden sonra alarm üretilmeden önce servis en çok Y kez otomatik yeniden başlatılır; her müdahale denetim kaydına yazılır ve gerçek sonuç izleme üzerinde gösterilir.</li>
                            <li><strong>Disk dolum tahmini:</strong> 30 günlük disk geçmişinden eğilim hesabıyla hangi disklerin 90 gün içinde dolacağı öngörülür.</li>
                            <li><strong>Dashboard ve istatistik:</strong> canlı grafikli sekmeli çoklu dashboard, DB sağlığı enstans paneli, widget'lı istatistik panosu (filo trendi, kapasite, en çok tüketenler, kesinti özeti, kullanım dağılımı, CPU ısı haritası, yaklaşan disk dolumları ve sertifika bitişleri…), tam ekran NOC modu, yazdırılabilir PDF yönetim raporu, CSV içe/dışa aktarma ve toplu düzenleme.</li>
                            <li><strong>Herkese açık durum sayfası:</strong> yayınlamayı seçtiğiniz izlemelerin anlık durumu ve 90 günlük uptime şeridiyle giriş gerektirmeyen <code>/durum</code> sayfası.</li>
                            <li><strong>Raporlama:</strong> 1 yıla kadar geriye dönük, tarih aralıklı erişilebilirlik raporları, kesinti detayları, ortalama/zirve kullanım istatistikleri.</li>
                            <li><strong>Kurumsal:</strong> LDAP/AD girişi + yerel kullanıcılar, granüler rol tabanlı yetkilendirme, iki adımlı giriş (e-posta/SMS/WhatsApp ile OTP), hash-zincirli değiştirilemez denetim kaydı, SIEM/syslog aktarımı, zamanlanmış ve şifreli yedekler, HashiCorp Vault entegrasyonu, çoklu veritabanı (SQLite, SQL Server, MySQL, Oracle, PostgreSQL), ilk kurulum sihirbazı, tek tıkla self-update, iki dilli arayüz (TR/EN) ve koyu tema.</li>
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-6">
        <div class="card-head"><i class="bi bi-shield-lock text-brand-500"></i> @T("Güvenlik", "Security")</div>
        <div class="card-body">
            <p class="text-slate-700 mb-4">
                @if (en)
                {
                    <text>vMon never stores the account passwords used in monitoring tests as plain text.
                    All passwords are encrypted using <strong>DPAPI (Data Protection API)</strong>, the enterprise-grade
                    data protection facility of the Windows operating system.</text>
                }
                else
                {
                    <text>vMon, izleme testlerinde kullanılan hesap şifrelerini hiçbir zaman düz metin olarak saklamaz.
                    Tüm şifreler, Windows işletim sisteminin kurumsal standartlardaki veri koruma altyapısı olan
                    <strong>DPAPI (Data Protection API)</strong> ile şifrelenerek kaydedilir.</text>
                }
            </p>
            <ul class="space-y-3">
                @{
                    var itemsTr = new (string, string)[] {
                        ("Makineye özel şifreleme", "Şifreleme anahtarları doğrudan Windows tarafından, sunucuya özgü olarak yönetilir. Veritabanı dosyası kopyalansa dahi şifreler yalnızca bu sunucu üzerinde çözülebilir."),
                        ("Uygulama içinde anahtar yok", "Kodda veya yapılandırma dosyalarında gömülü herhangi bir şifreleme anahtarı bulunmaz; anahtar yönetimi tamamen işletim sistemine aittir."),
                        ("Yalnızca kullanım anında çözme", "Şifreler sadece servis kontrolü çalıştığı anda bellekte çözülür; diske yazılmaz ve günlük kayıtlarına geçmez."),
                        ("Arayüzde gizlilik", "Kayıtlı şifreler hiçbir ekranda geri gösterilmez; düzenleme sırasında yalnızca yeni şifre girilebilir."),
                        ("HashiCorp Vault entegrasyonu", "Kimlik bilgileri merkezi Vault kasasından kontrol anında güvenli biçimde çekilebilir; uygulama hiçbir gizli değeri kalıcı saklamak zorunda kalmaz."),
                        ("LDAP / Active Directory ile oturum açma", "Uygulamaya erişim kurumsal kimliklerle korunur; yalnızca belirlenen güvenlik grubunun üyeleri giriş yapabilir."),
                        ("Rol tabanlı yetkilendirme", "Yapılandırma ekranı yalnızca uygulama adminlerine açıktır; diğer kullanıcılar izleme ve raporlamayı tüm gücüyle kullanırken kritik ayarlar güvende kalır.")
                    };
                    var itemsEn = new (string, string)[] {
                        ("Machine-specific encryption", "Encryption keys are managed directly by Windows, specific to this server. Even if the database file is copied, passwords can only be decrypted on this server."),
                        ("No keys inside the application", "There are no encryption keys embedded in the code or configuration files; key management belongs entirely to the operating system."),
                        ("Decryption only at use time", "Passwords are decrypted in memory only while a service check runs; they are never written to disk or to logs."),
                        ("Confidential in the UI", "Saved passwords are never shown back on any screen; during editing only a new password can be entered."),
                        ("HashiCorp Vault integration", "Credentials can be securely pulled from a central Vault at check time; the application never has to persist any secret."),
                        ("LDAP / Active Directory sign-in", "Access is protected with corporate identities; only members of the designated security group can sign in."),
                        ("Role-based authorization", "The configuration screen is open only to application admins; other users get the full power of monitoring and reporting while critical settings stay safe.")
                    };
                    var secItems = en ? itemsEn : itemsTr;
                }
                @foreach (var item in secItems)
                {
                    <li class="flex gap-3">
                        <i class="bi bi-check-circle-fill text-emerald-500 mt-0.5"></i>
                        <span class="text-slate-700"><strong>@item.Item1:</strong> @item.Item2</span>
                    </li>
                }
            </ul>
        </div>
    </div>

    <div class="card mb-6" x-data="{ open:false }">
        <div class="card-head cursor-pointer select-none" @@click="open=!open">
            <span><i class="bi bi-patch-check text-brand-500"></i> @T("Regülasyon Uyumları", "Regulatory Compliance")</span>
            <i class="bi text-slate-400" :class="open ? 'bi-chevron-up' : 'bi-chevron-down'"></i>
        </div>
        <div class="card-body" x-show="open" x-cloak>
            <p class="text-sm text-slate-500 mb-4">
                @T("vMon'un sektör güvenlik düzenlemelerinin ilgili maddeleriyle eşlemesi. Bu bir öz-değerlendirme/haritalamadır (resmi sertifika değildir). Kapsanan çerçeveler: PCI DSS, NIST, ISO/IEC 27001, CIS, OWASP ASVS.",
                       "Mapping of vMon to relevant clauses of industry security frameworks. This is a self-assessment/mapping (not a formal certification). Frameworks covered: PCI DSS, NIST, ISO/IEC 27001, CIS, OWASP ASVS.")
            </p>
            @{
                var compTr = new (string ctrl, string refs, string desc)[] {
                    ("Rol tabanlı erişim (RBAC) + admin ayrımı", "PCI 7.x · ISO A.5.15/A.5.18 · NIST AC-2/AC-6 · CIS 6", "Ayarlar ve Kullanıcılar yalnız adminlere açık; her kullanıcı en az ayrıcalık ilkesiyle granüler izinlerle çalışır."),
                    ("Çok faktörlü doğrulama (OTP)", "PCI 8.5 · NIST IA-2 (AAL2) · ISO A.8.5", "Şifreden sonra e-posta/SMS/WhatsApp ile tek kullanımlık kod; yöneticiler için zorunlu kılınabilir."),
                    ("Kaba kuvvet kilitleme", "PCI 8.3.4 · NIST AC-7 · CIS 6", "Ardışık başarısız girişlerde hesap geçici kilitlenir (eşik ve süre yapılandırılır)."),
                    ("Boşta oturum zaman aşımı (15 dk)", "PCI 8.2.8 · NIST AC-12", "Belirli süre işlem yapılmazsa oturum otomatik sonlanır."),
                    ("Güçlü parola saklama (PBKDF2)", "PCI 8.3.x · NIST IA-5 · ISO A.8.24", "Yerel kullanıcı parolaları PBKDF2-SHA256 (100k iterasyon + tuz) ile saklanır; düz metin yoktur."),
                    ("Hesap yaşam döngüsü", "PCI 8.2.4-8.2.5 · NIST AC-2", "AD güvenlik grubundan düşen kullanıcılar senkronda pasifleşir ve giriş yapamaz."),
                    ("Denetim kaydı + saklama", "PCI 10.2/10.5.1 · ISO A.8.15 · NIST AU-2/AU-11 · CIS 8", "Tüm yönetimsel işlemler UTC zaman damgalı kaydedilir; ≥1 yıl saklanır; salt-okunur ekranla izlenir."),
                    ("Aktarımda şifreleme (TLS)", "PCI 4.2.1 · NIST SC-8 · ISO A.8.24", "LDAPS/Vault bağlantılarında sertifika doğrulaması varsayılan açık; uygulama için HTTPS/HSTS zorlanabilir."),
                    ("Sırların şifreli saklanması", "PCI 3.x · NIST SC-28 · ISO A.8.24", "İzleme kimlik bilgileri DPAPI ile şifrelidir; Vault ile hiç saklanmadan da çekilebilir."),
                    ("CSRF + enjeksiyon koruması", "OWASP ASVS · NIST SI-10", "Tüm formlarda antiforgery token; veritabanı erişimi parametrelidir (SQL enjeksiyonuna kapalı)."),
                    ("Backdoor yok / en az ayrıcalık", "NIST CM-7 · CIS 4", "Dosya tabanlı kurtarma/oturum atlama mekanizmaları kaldırıldı; uzaktan bypass yolu yoktur."),
                    ("Yedekleme & kurtarma", "ISO A.5.30 · NIST CP-9 · CIS 11", "Tutarlı (online) yedek + zamanlanmış yedek + geri yükleme ile iş sürekliliği."),
                    ("Hata gizliliği", "OWASP ASVS · NIST SI-11", "Hata sayfası teknik ayrıntı sızdırmaz; tam ayrıntı yalnız sunucu loglarındadır."),
                    ("Değiştirilemez denetim kaydı (hash-zinciri)", "PCI 10.3.x · NIST AU-9 · ISO A.8.15", "Her kayıt öncekinin SHA-256 hash'ini içerir; değiştirilen/silinen kayıt 'Bütünlüğü Doğrula' ile tespit edilir."),
                    ("Sıkı güvenlik başlıkları + CSP", "OWASP ASVS · NIST SC-7", "Content-Security-Policy, X-Frame-Options (clickjacking), nosniff, Referrer-Policy, Permissions-Policy."),
                    ("Yerel parola politikası + tekrar engeli", "PCI 8.3.6/8.3.7 · NIST IA-5", "Yapılandırılır min uzunluk/karmaşıklık; son N parola tekrar kullanılamaz."),
                    ("SIEM / syslog aktarımı", "PCI 10.5.4 · NIST AU-6 · ISO A.8.15", "Denetim olayları merkezi syslog sunucusuna iletilebilir (kurcalamaya dirençli, merkezi)."),
                    ("Şifreli yedekler", "PCI 3.x/9.4.1 · ISO A.8.24", "Yedek dosyaları AES-256 ile parolayla şifrelenebilir; kopyalansa bile parola olmadan açılamaz."),
                    ("Hız sınırlama (rate limiting)", "OWASP · NIST SC-5", "Kimlik doğrulama uçlarında IP başına istek sınırı — kaba kuvvet/DoS direnci."),
                    ("Sorumlu açıklama (security.txt)", "RFC 9116 · OWASP", "/.well-known/security.txt ile güvenlik iletişim noktası yayımlanır.")
                };
                var compEn = new (string ctrl, string refs, string desc)[] {
                    ("Role-based access (RBAC) + admin separation", "PCI 7.x · ISO A.5.15/A.5.18 · NIST AC-2/AC-6 · CIS 6", "Settings and Users are admin-only; every user runs with least-privilege granular permissions."),
                    ("Multi-factor authentication (OTP)", "PCI 8.5 · NIST IA-2 (AAL2) · ISO A.8.5", "One-time code via email/SMS/WhatsApp after the password; can be enforced for administrators."),
                    ("Brute-force lockout", "PCI 8.3.4 · NIST AC-7 · CIS 6", "Account is temporarily locked after consecutive failed logins (threshold and duration configurable)."),
                    ("Idle session timeout (15 min)", "PCI 8.2.8 · NIST AC-12", "Session ends automatically after a period of inactivity."),
                    ("Strong password storage (PBKDF2)", "PCI 8.3.x · NIST IA-5 · ISO A.8.24", "Local user passwords are stored with PBKDF2-SHA256 (100k iterations + salt); never in plain text."),
                    ("Account lifecycle", "PCI 8.2.4-8.2.5 · NIST AC-2", "Users removed from the AD security group are deactivated on sync and cannot sign in."),
                    ("Audit logging + retention", "PCI 10.2/10.5.1 · ISO A.8.15 · NIST AU-2/AU-11 · CIS 8", "All administrative actions are logged with UTC timestamps; retained ≥1 year; viewable read-only."),
                    ("Encryption in transit (TLS)", "PCI 4.2.1 · NIST SC-8 · ISO A.8.24", "Certificate validation is on by default for LDAPS/Vault; HTTPS/HSTS can be enforced for the app."),
                    ("Secrets encrypted at rest", "PCI 3.x · NIST SC-28 · ISO A.8.24", "Monitoring credentials are DPAPI-encrypted; with Vault they need not be stored at all."),
                    ("CSRF + injection protection", "OWASP ASVS · NIST SI-10", "Antiforgery token on all forms; database access is parameterized (closed to SQL injection)."),
                    ("No backdoors / least privilege", "NIST CM-7 · CIS 4", "File-based recovery/login-bypass mechanisms were removed; there is no remote bypass path."),
                    ("Backup & recovery", "ISO A.5.30 · NIST CP-9 · CIS 11", "Consistent (online) backup + scheduled backup + restore for business continuity."),
                    ("Error confidentiality", "OWASP ASVS · NIST SI-11", "The error page leaks no technical detail; full detail is only in server logs."),
                    ("Tamper-evident audit log (hash chain)", "PCI 10.3.x · NIST AU-9 · ISO A.8.15", "Each entry includes the previous one's SHA-256 hash; modified/deleted entries are caught by 'Verify Integrity'."),
                    ("Strict security headers + CSP", "OWASP ASVS · NIST SC-7", "Content-Security-Policy, X-Frame-Options (clickjacking), nosniff, Referrer-Policy, Permissions-Policy."),
                    ("Password policy + reuse prevention", "PCI 8.3.6/8.3.7 · NIST IA-5", "Configurable min length/complexity; the last N passwords cannot be reused."),
                    ("SIEM / syslog forwarding", "PCI 10.5.4 · NIST AU-6 · ISO A.8.15", "Audit events can be forwarded to a central syslog server (tamper-resistant, centralized)."),
                    ("Encrypted backups", "PCI 3.x/9.4.1 · ISO A.8.24", "Backup files can be AES-256 password-encrypted; even if copied they cannot be opened without the password."),
                    ("Rate limiting", "OWASP · NIST SC-5", "Per-IP request limit on authentication endpoints — brute-force/DoS resilience."),
                    ("Responsible disclosure (security.txt)", "RFC 9116 · OWASP", "A security contact is published at /.well-known/security.txt.")
                };
                var comp = en ? compEn : compTr;
            }
            <div class="overflow-x-auto">
                <table class="tbl text-sm">
                    <thead>
                        <tr>
                            <th class="whitespace-nowrap">@T("Uygulanan Kontrol", "Implemented Control")</th>
                            <th class="whitespace-nowrap">@T("İlgili Maddeler", "Mapped Clauses")</th>
                            <th>@T("Açıklama", "Explanation")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in comp)
                        {
                            <tr>
                                <td class="font-semibold text-slate-800 align-top"><i class="bi bi-check-circle-fill text-emerald-500"></i> @c.ctrl</td>
                                <td class="mono text-xs text-slate-500 align-top whitespace-nowrap">@c.refs</td>
                                <td class="text-slate-600 align-top">@c.desc</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <p class="text-xs text-slate-400 mt-3">
                @T("Not: Eşleme bilgilendirme amaçlıdır; resmi denetim/sertifika yerine geçmez. Tam veri-at-rest şifreleme gibi ek kontroller yol haritasındadır.",
                   "Note: This mapping is informational and does not replace a formal audit/certification. Additional controls such as full data-at-rest encryption are on the roadmap.")
            </p>
        </div>
    </div>
</div>

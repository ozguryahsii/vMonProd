        <h1 class="text-3xl font-bold">vMon</h1>
        <p class="text-slate-300 mt-1">@T("Servis Ä°zleme ve Raporlama Platformu", "Service Monitoring & Reporting Platform")</p>
    </div>

    <div class="card mb-6">
        <div class="card-head"><i class="bi bi-info-circle text-brand-500"></i> @T("Genel Bilgiler", "General Information")</div>
        <div class="card-body space-y-4">
            <div class="flex gap-3">
                <div class="w-44 shrink-0 font-medium text-slate-600"><i class="bi bi-person-badge text-brand-500"></i> @T("GeliÅŸtiren", "Developed by")</div>
                <div class="text-slate-700">Ã–zgÃ¼r Adnan YahÅŸi</div>
            </div>
            <div class="flex gap-3">
                <div class="w-44 shrink-0 font-medium text-slate-600"><i class="bi bi-calendar3 text-brand-500"></i> @T("YapÄ±m Tarihi", "Build Date")</div>

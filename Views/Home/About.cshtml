@{
    ViewData["Title"] = "Hakkında";
    // Dil çerezine göre sunucu-taraflı iki dillilik (About baştan sona seçilen dilde gösterilir)
    var en = Context.Request.Cookies["vmon_lang"] == "en";
    string T(string tr, string eng) => en ? eng : tr;
    // React /app/about içine gömülü görünüm: üst menü gizlenir, zemin şeffaf (tek içerik kaynağı)
    var embed = Context.Request.Query["embed"] == "1";
}
@if (embed)
{
    <style>
        nav.vnav { display: none !important; }
        body { background: transparent !important; }
        main { padding-top: 0 !important; }
    </style>
}

<div class="max-w-4xl mx-auto">
    <div class="rounded-2xl bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white p-8 text-center mb-6 shadow-lg">
        <div class="logo-box inline-flex items-center justify-center h-14 w-14 rounded-2xl bg-brand-500 shadow-lg shadow-brand-500/40 mb-3">
            <i class="bi bi-activity text-2xl logo-anim"></i>
        </div>
        <h1 class="text-3xl font-bold">vMon</h1>
        <p class="text-slate-300 mt-1">@T("Servis İzleme ve Raporlama Platformu", "Service Monitoring & Reporting Platform")</p>
    </div>

    <div class="card mb-6">
        <div class="card-head"><i class="bi bi-info-circle text-brand-500"></i> @T("Genel Bilgiler", "General Information")</div>
        <div class="card-body space-y-4">
            <div class="flex gap-3">
                <div class="w-44 shrink-0 font-medium text-slate-600"><i class="bi bi-person-badge text-brand-500"></i> @T("Geliştiren", "Developed by")</div>
                <div class="text-slate-700">Özgür Adnan Yahşi</div>
            </div>
            <div class="flex gap-3">
                <div class="w-44 shrink-0 font-medium text-slate-600"><i class="bi bi-calendar3 text-brand-500"></i> @T("Yapım Tarihi", "Build Date")</div>
                <div class="text-slate-700">@T("Haziran 2026", "June 2026")</div>
            </div>
            <div class="flex gap-3" x-data="{ open:false }">
                <div class="w-44 shrink-0 font-medium text-slate-600"><i class="bi bi-tag text-brand-500"></i> @T("Versiyon", "Version")</div>
                <div class="text-slate-700 flex-1">
                    <button type="button" @@click="open=!open" class="inline-flex items-center gap-2 group">
                        <span class="badge pill-info">v2.23.0-pre.27</span>
                        <span class="text-xs text-brand-600 group-hover:underline">@T("Sürüm notları", "Release notes") <i class="bi" :class="open ? 'bi-chevron-up' : 'bi-chevron-down'"></i></span>
                    </button>
                    <div x-show="open" x-cloak class="mt-3 rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm leading-relaxed text-slate-600">
                        @if (en)
                        {
                            <p class="font-semibold text-slate-700 mb-2">Version 2.21.0 — Compliance pack (SIEM, encrypted backups, rate limiting)</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.21.0)</strong> SIEM/syslog forwarding of audit events (PCI 10.5.4); password-reuse prevention (PCI 8.3.7); AES-256 encrypted backups (PCI 3.x); per-IP rate limiting on login (NIST SC-5); and a security.txt (RFC 9116). All DB-agnostic, no structural changes.</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.20.2 — Security headers &amp; password policy</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.20.2)</strong> A full Content-Security-Policy plus hardened security headers are now sent on every response (clickjacking/MIME/external-source restrictions). Configurable local password policy (min length + complexity), enforced at setup and on password change; local users can change their own password from My Profile. OWASP ASVS · PCI 8.3.6 · NIST 800-63B · SC-7.</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.20.1 — Tamper-evident audit log</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.20.1)</strong> The audit log is now hash-chained (each entry includes the SHA-256 hash of the previous). A "Verify Integrity" button detects any modified or deleted entry. Works on every database. PCI DSS 10.3.x · NIST AU-9 · ISO 27001 A.8.15.</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.20.0 — Regulatory compliance section</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.20.0)</strong> About now has a collapsible "Regulatory Compliance" section mapping vMon to PCI DSS / NIST / ISO 27001 / CIS / OWASP ASVS clauses with explanations (bilingual). Start of the compliance phase. Windows CPU now uses a processor-group-aware counter (fixes under-reporting on 64+ core servers).</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.19.2 — Three-column Settings</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.19.2)</strong> Settings are now a single page in three balanced columns with the section menu removed — denser, gap-free. Functions unchanged.</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.19.1 — Compact two-column Settings</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.19.1)</strong> Settings now use two independent balanced columns (no empty gaps), tighter/compact fields and cards, related settings grouped, single page with a sticky section menu. Nothing functional changed.</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.19.0 — Settings fix &amp; chart/CPU tweaks</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.19.0) Settings:</strong> fixed a regression where only the first section showed. Rebuilt as a single page in a two-column layout with a sticky section menu that smooth-scrolls to each group. All settings &amp; functions intact.</li><li><strong>(2.19.0)</strong> Fleet/Capacity chart legends no longer overlap the axis. Windows CPU is now read twice (short interval) to avoid an occasional cold/low first reading.</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.18.0 — Redesigned Settings &amp; EOL drill-down</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.18.0) Settings redesign:</strong> the long single column is now organised into tabs (Monitoring, Notifications, Access &amp; Login, Security, Data &amp; Backup, Other) with related settings grouped together and a sticky Save bar. No setting's function changed.</li><li><strong>(2.18.0)</strong> In Statistics, clicking an end-of-life OS row now lists exactly which servers run that version.</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.17.0 — Real EOL via endoflife.date</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.17.0) End-of-life check:</strong> optional integration with endoflife.date for real OS support-end dates (past-EOL and "soon" warnings). Privacy-safe — your inventory never leaves; only public version tables are downloaded and matched locally, cached, refreshed weekly. Air-gapped sites can import the data as JSON. Falls back to the static list when disabled. Configure under Settings → End-of-Life (EOL).</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.16.0 — PDF report &amp; outage drill-down</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.16.0) Management report:</strong> a new "PDF Report" button opens a clean, branded, printable report (KPIs, OS distribution, fleet trend, top consumers, uptime, outages, EOL) — print or save as PDF for weekly/monthly reviews.</li><li><strong>(2.16.0)</strong> Outage summary bars are now clickable — click a day to see that day's outages (server, start/end, duration). Detail dialog headers no longer overlap rows when scrolling.</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.15.3 — Build fix</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.15.3)</strong> Fixes the v2.15.2 release build (a missing using directive). Same content as 2.15.2.</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.15.2 — Faster stats &amp; histogram drill-down</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.15.2) Performance:</strong> time-series indexes added, statistics aggregation pushed into the database (no longer loads raw rows), and the result is briefly cached — the Statistics (and Reports) pages open much faster. Same data, same features.</li><li><strong>(2.15.2)</strong> Click a bar in the Usage Distribution widget to see which servers fall in that band (e.g. 40-60% CPU).</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.15.1 — Capacity CPU &amp; rising usage</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.15.1)</strong> The Capacity widget now has a CPU tab (used vs allocated cores) alongside RAM/Disk. New "Rising usage" widget lists servers whose CPU/RAM/Disk usage rose more than 10 points vs ~7 days ago.</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.15.0 — Statistics insight pack</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.15.0)</strong> Nine new widgets: Fleet trend (30-day CPU/RAM/Disk), Top resource consumers, Critical (disk 85%+/threshold), Uptime (24h/7d), Usage histogram, Capacity used-vs-allocated, Outage summary, EOL OS, and a CPU heatmap. Resource cards now show a mini sparkline.</li><li><strong>(2.15.0)</strong> Page tools: fullscreen (NOC mode), last-updated time, summary CSV export, and a "reset to default layout" button (use it to get the new widgets on an existing dashboard).</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.14.1 — Emails on sync</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.14.1)</strong> "Sync from LDAP" now also pulls each member's email — so all users' emails fill in at once, not only after they log in.</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.14.0 — OTP safeguards &amp; LDAP email</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.14.0)</strong> LDAP logins now auto-fetch the user's email (AD <code>mail</code>) and store it — shown on the Users screen and used for email OTP.</li><li><strong>(2.14.0)</strong> Enabling OTP is now blocked unless at least one active admin has the contact (email/phone) for the selected channel — prevents locking everyone out.</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.13.2 — Pie drill-down</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.13.2)</strong> Clicking a pie (or its center number) now opens a numeric category breakdown as bars (e.g. 95 Windows / 144 Linux); clicking a category drills into the matching servers, with a "back to categories" button.</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.13.1 — Trend ranges</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.13.1)</strong> The detail dialog trend now has selectable ranges — 7 days / 1 month / 3 months / 6 months / 1 year — bucketed daily, weekly or monthly as the range grows. (Long ranges depend on the history retention setting.)</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.13.0 — Statistics polish</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.13.0)</strong> Statistics now sources everything from health-monitored servers only (Windows Health + Linux Health) — so "Total servers" and Up/Down/Error are correct and consistent.</li><li><strong>(2.13.0)</strong> Dark theme support on the Statistics page; pie tooltips no longer clipped (full name shows). Click any chart, counter or slice to open a detail dialog listing the matching servers and a 7-day trend for CPU/RAM/Disk.</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.12.3 — Restore crash fix &amp; hardening</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.12.3) Critical fix:</strong> after restoring an older database, newly added required columns were left NULL, which crashed login and other pages ("data is NULL at ordinal N"). Startup now backfills those NULLs with safe defaults — existing data recovers automatically.</li><li><strong>(2.12.3) Security hardening:</strong> the file-based recovery (reset-admin / disable-auth) was removed. The error page no longer leaks exception details — it shows a generic message with a reference id; full detail goes to the logs only.</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.12.2 — Recovery &amp; visible errors</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.12.2) Break-glass recovery:</strong> drop a <code>Data\reset-admin.txt</code> file containing <code>username|password</code> to (re)create a local admin and grant it admin rights on next start. Or drop <code>Data\disable-auth.txt</code> to temporarily turn off the login requirement (open mode) if login is broken. The file is consumed and deleted automatically.</li><li><strong>(2.12.2) Visible errors:</strong> the error page is no longer hidden behind the login redirect — unhandled errors are logged and their summary is shown, so problems are diagnosable instead of looking like "login does nothing".</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.12.1 — Local user lockout fix</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.12.1)</strong> LDAP sync no longer deactivates local users (e.g. the setup admin) — they are not tied to AD group membership. On startup any local user that was wrongly deactivated is reactivated automatically, so an existing locked install recovers on upgrade (no reinstall).</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.12.0 — Statistics dashboard</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.12.0) Statistics tab:</strong> a new widget-based analytics board (Apache ECharts + Gridstack + CountUp). Counters, used-vs-allocated CPU/RAM/Disk, OS distribution (full version auto-detected on Windows &amp; Linux health checks), and Tag-based pie charts. Drag/resize is behind an edit-lock (like Zabbix); admins arrange the shared layout. Health checks now store structured CPU cores / RAM &amp; disk GB and the exact OS version.</li><li><strong>(2.12.0)</strong> "Keyword" is now called <strong>Tag</strong> (Etiket) across Services and Reports.</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.11.1 — Large restore fix</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.11.1)</strong> Restoring a large database (e.g. 180&nbsp;MB) no longer fails with HTTP 400 — the upload limit was raised, and a new <em>restore from a server-side path</em> option was added (no upload limit, ideal for big files already on the server).</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.11.0 — SQLite backup & restore</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.11.0) Backup &amp; restore:</strong> Settings now has a Backup section — pick a server-side folder, take a consistent (online) backup on demand, or schedule a daily one with retention. Restore from the list or upload a <code>.db</code> from another machine (used to migrate an old database). Works independently of any external DB tooling; SQLite only.</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.10.0 — Two-factor login (OTP)</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.10.0) Two-step verification:</strong> after the password, an optional one-time code is required. Channel is configurable in Settings — <strong>Email (SMTP), SMS or WhatsApp</strong> — and the code is sent to the user's own email/phone (set in the new <em>My Profile</em> page). 6-digit code, 5-minute expiry, attempt-limited.</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.9.2 — Service restart & cleaner startup</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.9.2)</strong> After setup, the app now restarts correctly in Windows Service mode (recovery-based). Startup no longer logs harmless EF errors (legacy blind ALTERs removed; schema handled by EnsureCreated + additive sync).</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.9.1 — Installer script fix</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.9.1)</strong> Installer scripts are now ASCII-safe so they run on Windows PowerShell 5.1 regardless of file encoding.</li></ul><p class="font-semibold text-slate-700 mb-2">Version 2.9.0 — Installer & dual hosting</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>(2.9.0) One-step install package:</strong> a self-contained release (no .NET needed on the target) with install / upgrade / uninstall scripts. Tagging a version builds the zip automatically.</li>
                                <li><strong>(2.9.0) IIS or Windows Service:</strong> the app can run either under IIS or as a Windows Service (Kestrel) — chosen by the installer. HTTPS handling is configurable for reverse-proxy setups.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Version 2.8.0 — UTC time handling</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>(2.8.0) UTC storage / local display:</strong> all timestamps are stored in UTC and shown in your local time. This keeps reports and history consistent across servers and time zones (cloud-ready).</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Version 2.7.0 — Safe schema upgrades</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>(2.7.0) Provider-independent schema sync:</strong> when a new version adds a column, it is added to the existing database automatically on any provider — additive only (never drops or alters), so there is no data-loss risk.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Version 2.6.0 — Multi-database & setup wizard</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>(2.6.0) Multiple databases:</strong> SQLite, SQL Server, PostgreSQL, MySQL and Oracle are supported. The provider is chosen at install time; the DB can be local or on a separate server.</li>
                                <li><strong>(2.6.0) First-run setup wizard:</strong> on a fresh install the app asks for the database (with a connection test), company name, an admin account and SMTP (optional, with a test send).</li>
                                <li><strong>(2.6.0) Local admin login:</strong> a password-protected local admin is created during setup, so the app requires sign-in from the start. LDAP can be configured later and the local account removed.</li>
                                <li class="text-slate-500">Under the hood: a DB-external bootstrap layer, a secret-protection abstraction (DPAPI today, cloud/AES-ready) and a hardened startup that never errors on first run.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Version 2.5.4 — Translation pass 2</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>(2.5.4) More English coverage:</strong> Dashboard edit, Service edit, Credential edit, Integration edit and Edit Permissions screens, the Reports table (types, durations, detail) and recurring Audit descriptions are now translated. The "(soon)" tag was removed from WhatsApp/Call (now live).</li>
                                <li class="text-slate-500">Note: native browser controls (file picker "Choose file", the date-time picker popup) follow the browser's own language and can't be forced from the app.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Version 2.5.3 — Wider translation & Voice/IVR merge</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>(2.5.3) Translation:</strong> The Reconciliation page is now fully bilingual (server-side); remaining Turkish labels in Audit and Settings (LDAP / Security & Compliance / Notification Channels / Login logo) were translated.</li>
                                <li><strong>(2.5.3) Voice Call / IVR merged:</strong> The separate "Voice Call" channel type was merged into "IVR" as a single <b>"Voice Call / IVR"</b> option (both do the same job). Existing Voice integrations are migrated automatically.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Version 2.5.2 — About in English & fixes</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>(2.5.2) About fully English:</strong> The About page is now rendered server-side in the selected language. From now on every change is written in both Turkish and English.</li>
                                <li><strong>(2.5.2) Dark theme fix:</strong> The service status cards at the bottom of the dashboard are no longer white in dark mode.</li>
                                <li><strong>(2.5.2) WhatsApp template restored:</strong> The approved template (Content SID) field was added to the WhatsApp integration (Notification Channels). When set, alarms are sent as interactive button templates again; the previous template is restored automatically and can be changed any time.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Version 2.5.x — Language (TR/EN) & theme</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>Language selection:</strong> A <b>Language</b> option (Turkish 🇹🇷 / English 🇬🇧) was added to the user menu; the choice is remembered per user and the UI is translated.</li>
                                <li><strong>Dark theme:</strong> Click your name (top right) → <b>Theme</b> → Light/Dark (a colour dot next to each). Remembered per user across logins and devices.</li>
                                <li><strong>Chart theming:</strong> Chart axis/grid colours follow the theme; UP/DOWN/ERROR/SLOW/TOTAL boxes are readable in dark mode.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Version 2.3.0 — Dashboard tabs merged</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li>The separate "Dashboard" menu item was removed. The main (unfiltered) view is now a fixed <b>"All"</b> first sub-tab inside "Dashboards"; it cannot be deleted or reordered.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Version 2.2.x — Notification Channels (single box)</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>One "Notification Channels" box:</strong> SMS / WhatsApp / Voice / IVR integrations are added, edited, deleted and toggled from one place in Settings. Pick the type when adding; each integration can use its own recipient list. No code changes needed.</li>
                                <li><strong>Flexible integration model:</strong> all channels use the same templated HTTP request (placeholders {to}/{from}/{message}/{user}/{password}/{apikey}). On an alarm, all active integrations matching the per-service switches (Mail/SMS/WhatsApp/Call) are triggered. The built-in Twilio settings were migrated into integrations automatically.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Version 2.1.x — Bulk edit & design</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>On/off switches:</strong> all active/passive checkboxes are now modern toggles (grey when off, green when on).</li>
                                <li><strong>Extended bulk edit:</strong> on Services, "Edit Selected" can change check interval, slowness threshold and CPU/RAM/Disk thresholds in bulk, and bulk-add keywords. On/off fields use segmented buttons (Keep/On/Off).</li>
                                <li><strong>Fix:</strong> when both Type and Keyword filters are chosen on a dashboard, their <b>intersection</b> is used.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Version 2.0.x — Interactive WhatsApp (Phase 4)</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>Templated alarm + buttons:</strong> alarms via an approved WhatsApp template ({{1}}..{{4}}) with Start / Restart / Stop buttons.</li>
                                <li><strong>Two-way control:</strong> pressing a button calls an inbound webhook that applies start/stop/restart to the related service; the result is replied over WhatsApp.</li>
                                <li><strong>Authorization & mapping:</strong> the phone number is mapped to a user (Phone field under Users); only users with the <b>"Manage alarms"</b> permission can act, others get a "no permission" reply. All actions are written to the Audit log.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Version 1.8–1.9 — SMS & WhatsApp notifications</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>SMS / WhatsApp notifications (Twilio):</strong> a message is sent when a service goes DOWN/ERROR/RECOVERED. Per-service "Alarm Management" controls the channels. Custom HTTP SMS providers (e.g. NetGSM) can be added without code.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Version 1.6–1.7 — Reconciliation, descriptions & fixes</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>Reconciliation module:</strong> cross-compares our inventory with the vendor's list (CSV/XLSX), highlighting missing/extra servers and CPU/RAM/Disk/IP/OS mismatches; fully independent and permission-gated.</li>
                                <li><strong>Service description</strong> field shown on dashboard cards, reports and CSV; the chart "Select Service" filter now also applies to the cards.</li>
                                <li><strong>Uptime fix:</strong> CPU/RAM/Disk threshold breaches (ERROR) no longer count as outages in availability reports.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Version 1.4–1.5 — Security hardening & authorization (PCI DSS / ISO 27001 / NIST)</p>
                            <ul class="list-disc ml-5 space-y-1.5">
                                <li><strong>Granular user authorization</strong> via the Users screen; CSRF protection, secure cookies, HTTPS/HSTS, security headers, login brute-force protection.</li>
                                <li><strong>Audit log</strong> of all sensitive actions with a read-only Audit screen; ≥1 year retention; 15-minute idle timeout; account lockout policy; outbound TLS validation on by default.</li>
                                <li><strong>Access review:</strong> users removed from the AD security group are deactivated on sync and cannot sign in.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mt-3 mb-2">Earlier — Version 1.3.0</p>
                            <ul class="list-disc ml-5 space-y-1.5">
                                <li>DOWN / ERROR classification; Windows/Linux service status monitoring + remote start/stop/restart; time ranges up to 1 month; advanced filtering.</li>
                            </ul>
                        }
                        else
                        {
                            <p class="font-semibold text-slate-700 mb-2">Sürüm 2.21.0 — Uyumluluk paketi (SIEM, şifreli yedek, rate limiting)</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.21.0)</strong> Denetim olaylarının SIEM/syslog'a aktarımı (PCI 10.5.4); parola tekrar-kullanım engeli (PCI 8.3.7); AES-256 şifreli yedekler (PCI 3.x); login'de IP başına hız sınırlama (NIST SC-5); ve security.txt (RFC 9116). Hepsi DB-bağımsız, yapısal değişiklik yok.</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.20.2 — Güvenlik başlıkları & parola politikası</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.20.2)</strong> Tüm yanıtlara tam Content-Security-Policy ve sıkılaştırılmış güvenlik başlıkları gönderiliyor (clickjacking/MIME/dış-kaynak kısıtları). Yapılandırılır yerel parola politikası (min uzunluk + karmaşıklık); kurulumda ve şifre değişiminde zorlanır; yerel kullanıcılar Profilim'den kendi şifresini değiştirebilir. OWASP ASVS · PCI 8.3.6 · NIST 800-63B · SC-7.</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.20.1 — Değiştirilemez denetim kaydı</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.20.1)</strong> Denetim kaydı artık hash-zincirli (her kayıt öncekinin SHA-256 hash'ini içerir). "Bütünlüğü Doğrula" düğmesi değiştirilmiş/silinmiş kaydı tespit eder. Her veritabanında çalışır. PCI DSS 10.3.x · NIST AU-9 · ISO 27001 A.8.15.</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.20.0 — Regülasyon uyumları bölümü</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.20.0)</strong> Hakkında'ya açılır "Regülasyon Uyumları" bölümü eklendi: vMon'un PCI DSS / NIST / ISO 27001 / CIS / OWASP ASVS maddeleriyle açıklamalı eşlemesi (iki dilli). Uyumluluk fazının başlangıcı. Windows CPU artık işlemci-grubu-farkında sayaç kullanıyor (64+ çekirdekli sunucularda eksik ölçümü giderir).</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.19.2 — Üç sütunlu Ayarlar</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.19.2)</strong> Ayarlar artık tek sayfa, üç dengeli sütun; bölüm menüsü kaldırıldı — daha yoğun, boşluksuz. İşlevler aynı.</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.19.1 — Kompakt iki sütunlu Ayarlar</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.19.1)</strong> Ayarlar artık iki bağımsız dengeli sütunda (boşluk yok), daha küçük/kompakt alan ve kartlar, ilgili ayarlar gruplu, tek sayfa + sabit bölüm menüsü. İşlevsel hiçbir şey değişmedi.</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.19.0 — Ayarlar düzeltmesi & grafik/CPU iyileştirmeleri</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.19.0) Ayarlar:</strong> yalnız ilk bölümün göründüğü hata giderildi. Tek sayfa, iki sütunlu düzen + sabit bölüm menüsü (tıklayınca yumuşak kaydırma). Tüm ayarlar ve işlevler korundu.</li><li><strong>(2.19.0)</strong> Filo/Kapasite grafik açıklamaları artık eksenle çakışmıyor. Windows CPU artık iki kez (kısa aralıkla) okunuyor; ara sıra olan "soğuk/düşük" ilk okuma engellendi.</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.18.0 — Yenilenen Ayarlar & EOL detayı</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.18.0) Ayarlar yeniden tasarımı:</strong> uzun tek sütun artık sekmelere ayrıldı (İzleme, Bildirimler, Erişim &amp; Oturum, Güvenlik, Veri &amp; Yedekleme, Diğer); ilgili ayarlar bir arada ve sabit (sticky) Kaydet çubuğu. Hiçbir ayarın işlevi değişmedi.</li><li><strong>(2.18.0)</strong> İstatistikler'de destek-sonu bir OS satırına tıklayınca o sürümü çalıştıran sunucular listelenir.</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.17.0 — endoflife.date ile gerçek EOL</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.17.0) Destek sonu kontrolü:</strong> OS sürümlerinin gerçek destek-sonu tarihleri için endoflife.date ile opsiyonel entegrasyon (geçmiş-EOL ve "yakında" uyarıları). Gizlilik güvenli — envanteriniz dışarı çıkmaz; yalnız genel sürüm tabloları indirilir ve yerelde eşleştirilir, cache'lenir, haftada bir tazelenir. Air-gapped ortamlar JSON olarak içe aktarabilir. Kapalıyken statik listeye düşer. Ayarlar → Destek Sonu (EOL) altından yapılandırın.</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.16.0 — PDF rapor & kesinti detayı</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.16.0) Yönetim raporu:</strong> yeni "PDF Rapor" düğmesi temiz, markalı, yazdırılabilir bir rapor açar (KPI'lar, OS dağılımı, filo trendi, en çok tüketenler, uptime, kesintiler, EOL) — haftalık/aylık sunum için yazdır veya PDF kaydet.</li><li><strong>(2.16.0)</strong> Kesinti özeti barları artık tıklanabilir — bir güne tıklayınca o günün kesintileri (sunucu, başlangıç/bitiş, süre) görünür. Detay penceresi başlıkları kaydırırken artık satırların üstüne binmiyor.</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.15.2 — Daha hızlı istatistik & histogram detayı</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.15.2) Performans:</strong> zaman-serisi indeksleri eklendi, istatistik toplaması veritabanına taşındı (artık ham satırları belleğe yüklemiyor) ve sonuç kısa süre önbelleğe alınıyor — İstatistikler (ve Raporlar) sayfaları çok daha hızlı açılıyor. Aynı veri, aynı özellikler.</li><li><strong>(2.15.2)</strong> Kullanım Dağılımı widget'ında bir bara tıklayınca o banttaki sunucular listelenir (ör. %40-60 CPU).</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.15.1 — Kapasite CPU & artan kullanım</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.15.1)</strong> Kapasite widget'ına RAM/Disk yanında CPU sekmesi (kullanılan vs atanan çekirdek) eklendi. Yeni "Kapasite kullanımı artan" widget'ı, CPU/RAM/Disk kullanımı ~7 gün öncesine göre 10 puandan fazla artan sunucuları listeler.</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.15.0 — İstatistik içgörü paketi</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.15.0)</strong> Dokuz yeni widget: Filo trendi (30 gün CPU/RAM/Disk), Top kaynak tüketenler, Kritik (disk %85+/eşik), Uptime (24s/7g), Kullanım dağılımı, Kapasite kullanılan-atanan, Kesinti özeti, EOL OS ve CPU ısı haritası. Kaynak kartlarında artık mini sparkline var.</li><li><strong>(2.15.0)</strong> Sayfa araçları: tam ekran (NOC modu), son güncelleme saati, özet CSV dışa aktarma ve "varsayılana dön" düğmesi (mevcut panoda yeni widget'ları almak için kullanın).</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.14.1 — Senkronda e-postalar</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.14.1)</strong> "LDAP'tan Senkronize Et" artık her üyenin e-postasını da çekiyor — böylece tüm kullanıcıların e-postaları, giriş yapmalarını beklemeden tek seferde dolar.</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.14.0 — OTP koruması & LDAP e-posta</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.14.0)</strong> LDAP girişlerinde kullanıcının e-postası (AD <code>mail</code>) otomatik çekilip saklanıyor — Kullanıcılar ekranında görünüyor ve e-posta OTP'sinde kullanılıyor.</li><li><strong>(2.14.0)</strong> OTP açmak artık, seçili kanal için iletişim bilgisi (e-posta/telefon) olan en az bir aktif admin yoksa engelleniyor — herkesi kilitlemeyi önler.</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.13.2 — Pasta detayına inme</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.13.2)</strong> Bir pastaya (veya ortasındaki sayıya) tıklayınca artık kategori dökümü sayısal barlar olarak açılıyor (örn. 95 Windows / 144 Linux); bir kategoriye tıklayınca o sunucular listeleniyor, "kategorilere dön" düğmesiyle geri dönülüyor.</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.13.1 — Trend aralıkları</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.13.1)</strong> Detay penceresindeki trend artık seçilebilir aralıklı — 7 gün / 1 ay / 3 ay / 6 ay / 1 yıl — aralık büyüdükçe günlük, haftalık veya aylık gruplanır. (Uzun aralıklar geçmiş saklama süresi ayarına bağlıdır.)</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.13.0 — İstatistikler iyileştirmeleri</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.13.0)</strong> İstatistikler artık tüm verileri yalnız sağlık ile izlenen sunuculardan (Windows Health + Linux Health) alıyor — böylece "Toplam Sunucu" ve Up/Down/Hata doğru ve tutarlı.</li><li><strong>(2.13.0)</strong> İstatistikler sayfasında koyu tema desteği; pasta tooltip'leri artık kırpılmıyor (ad tam görünüyor). Herhangi bir grafiğe, sayaca veya dilime tıklayınca eşleşen sunucuları listeleyen ve CPU/RAM/Disk için 7 günlük trend gösteren bir detay penceresi açılıyor.</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.12.3 — Geri yükleme çökmesi düzeltmesi & sıkılaştırma</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.12.3) Kritik düzeltme:</strong> eski bir veritabanı geri yüklendiğinde sonradan eklenen zorunlu kolonlar NULL kalıyor, bu da giriş ve diğer sayfaları çökertiyordu ("data is NULL at ordinal N"). Açılışta bu NULL'lar güvenli varsayılanlarla dolduruluyor — mevcut veri otomatik kurtarılır.</li><li><strong>(2.12.3) Güvenlik sıkılaştırması:</strong> dosya tabanlı kurtarma (reset-admin / disable-auth) kaldırıldı. Hata sayfası artık istisna ayrıntısı sızdırmıyor — genel mesaj + referans no gösteriyor; tam ayrıntı yalnızca loglarda.</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.12.2 — Kurtarma & görünür hatalar</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.12.2) Break-glass kurtarma:</strong> <code>Data\reset-admin.txt</code> dosyasına <code>kullanıcı|şifre</code> yazıp koyun; açılışta yerel admin oluşturulur/sıfırlanır ve admin yapılır. Login tamamen bozuksa <code>Data\disable-auth.txt</code> koyarak oturum zorunluluğunu geçici kapatın (açık mod). Dosya otomatik kullanılıp silinir.</li><li><strong>(2.12.2) Görünür hatalar:</strong> hata sayfası artık login yönlendirmesinin arkasında gizlenmiyor — işlenmeyen hatalar loglanır ve özeti gösterilir; "login hiçbir şey yapmıyor" gibi görünen sorunlar teşhis edilebilir olur.</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.12.1 — Yerel kullanıcı kilitlenme düzeltmesi</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.12.1)</strong> LDAP senkronu artık yerel kullanıcıları (ör. kurulumdaki admin) pasifleştirmiyor — onlar AD grup üyeliğine bağlı değil. Açılışta yanlışlıkla pasife düşmüş yerel kullanıcılar otomatik aktifleştirilir; böylece kilitlenmiş mevcut kurulum upgrade ile kendiliğinden açılır (yeniden kuruluma gerek yok).</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.12.0 — İstatistikler panosu</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.12.0) İstatistikler sekmesi:</strong> widget'lı yeni analitik pano (Apache ECharts + Gridstack + CountUp). Sayaçlar, kullanılan/atanan CPU/RAM/Disk, OS dağılımı (Windows &amp; Linux sağlık kontrolünde tam sürüm otomatik tespit edilir) ve Etiket bazlı pasta grafikleri. Sürükle/boyutlandır bir <b>düzenleme kilidi</b> arkasında (Zabbix gibi); ortak düzeni adminler ayarlar. Sağlık kontrolleri artık yapısal CPU çekirdek / RAM &amp; disk GB ve tam OS sürümünü saklıyor.</li><li><strong>(2.12.0)</strong> "Keyword" artık Servisler ve Raporlar'da <strong>Etiket</strong> (Tag) olarak adlandırılıyor.</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.11.1 — Büyük geri yükleme düzeltmesi</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.11.1)</strong> Büyük veritabanı (örn. 180&nbsp;MB) geri yüklerken alınan HTTP 400 hatası giderildi — yükleme limiti yükseltildi ve yeni bir <em>sunucudaki yoldan geri yükle</em> seçeneği eklendi (yükleme limiti yok; sunucuda zaten duran büyük dosyalar için ideal).</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.11.0 — SQLite yedekleme & geri yükleme</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.11.0) Yedekleme &amp; geri yükleme:</strong> Ayarlar'a Yedekleme bölümü geldi — sunucu tarafında bir klasör seçip elle <b>tutarlı (online)</b> yedek alın ya da retention ile günlük zamanlanmış yedek kurun. Listeden ya da başka makineden yüklenen bir <code>.db</code> ile geri yükleyin (eski veritabanını taşımak için). Harici DB araçlarından bağımsız çalışır; yalnızca SQLite.</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.10.0 — İki adımlı giriş (OTP)</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.10.0) İki adımlı doğrulama:</strong> şifreden sonra isteğe bağlı tek kullanımlık kod istenir. Kanal Ayarlar'dan seçilir — <strong>E-posta (SMTP), SMS veya WhatsApp</strong> — ve kod kullanıcının kendi e-posta/telefonuna gider (yeni <em>Profilim</em> sayfasından girilir). 6 haneli kod, 5 dakika geçerli, deneme sınırlı.</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.9.2 — Servis yeniden başlatma & temiz açılış</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.9.2)</strong> Kurulumdan sonra uygulama Windows Service modunda artık doğru yeniden başlar (servis kurtarma ile). Açılışta zararsız EF hataları loglanmıyor (eski körleme ALTERlar kaldırıldı; şema EnsureCreated + eklemeli senkron ile).</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.9.1 — Kurulum script düzeltmesi</p><ul class="list-disc ml-5 space-y-1.5 mb-3"><li><strong>(2.9.1)</strong> Kurulum scriptleri ASCII-güvenli yapıldı; Windows PowerShell 5.1 üzerinde dosya kodlamasından bağımsız çalışır.</li></ul><p class="font-semibold text-slate-700 mb-2">Sürüm 2.9.0 — Kurulum paketi & çift hosting</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>(2.9.0) Tek adımda kurulum paketi:</strong> kendi içinde çalışan (hedefte .NET gerekmez) sürüm + kur/güncelle/kaldır scriptleri. Sürüm etiketlenince zip otomatik üretilir.</li>
                                <li><strong>(2.9.0) IIS veya Windows Service:</strong> uygulama IIS altında ya da Windows Service (Kestrel) olarak çalışabilir — kurulumda seçilir. HTTPS davranışı ters proxy senaryoları için yapılandırılabilir.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Sürüm 2.8.0 — UTC zaman yönetimi</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>(2.8.0) UTC sakla / yerel göster:</strong> tüm zaman damgaları UTC saklanır ve yerel saatinizle gösterilir. Bu, raporları ve geçmişi sunucular ve zaman dilimleri arasında tutarlı tutar (cloud'a hazır).</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Sürüm 2.7.0 — Güvenli şema yükseltme</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>(2.7.0) Provider-bağımsız şema senkronu:</strong> yeni sürüm bir kolon eklediğinde, bu kolon var olan veritabanına her sağlayıcıda otomatik eklenir — yalnızca ekleme yapar (asla silmez/değiştirmez), böylece veri kaybı riski yoktur.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Sürüm 2.6.0 — Çoklu veritabanı & kurulum sihirbazı</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>(2.6.0) Çoklu veritabanı:</strong> SQLite, SQL Server, PostgreSQL, MySQL ve Oracle desteklenir. Sağlayıcı kurulumda seçilir; veritabanı yerelde veya ayrı bir sunucuda olabilir.</li>
                                <li><strong>(2.6.0) İlk kurulum sihirbazı:</strong> sıfır kurulumda uygulama veritabanını (bağlantı testiyle), şirket adını, yönetici hesabını ve SMTP'yi (opsiyonel, test gönderimiyle) sorar.</li>
                                <li><strong>(2.6.0) Yerel admin girişi:</strong> kurulumda şifreli bir yerel admin oluşturulur; uygulama baştan itibaren giriş ister. LDAP sonradan bağlanıp yerel hesap silinebilir.</li>
                                <li class="text-slate-500">Altyapı: DB-dışı bootstrap katmanı, sır şifreleme soyutlaması (bugün DPAPI, cloud/AES'e hazır) ve ilk açılışta asla hata vermeyen sertleştirilmiş başlangıç.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Sürüm 2.5.4 — Çeviri turu 2</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>(2.5.4) Daha geniş İngilizce:</strong> Dashboard düzenle, Servis düzenle, Kimlik düzenle, Entegrasyon düzenle ve Yetki düzenle ekranları, Raporlar tablosu (tipler, süreler, detay) ve sık geçen Denetim açıklamaları çevrildi. WhatsApp/Arama yanındaki "(yakında)" etiketi kaldırıldı (artık yayında).</li>
                                <li class="text-slate-500">Not: tarayıcının native kontrolleri (dosya seçici "Dosya Seç", tarih-saat seçici popup) tarayıcının kendi diline bağlıdır, uygulamadan zorlanamaz.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Sürüm 2.5.3 — Geniş çeviri & Sesli/IVR birleştirme</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>(2.5.3) Çeviri:</strong> Mutabakat sayfası artık tamamen iki dilli (sunucu-taraflı); Denetim ve Ayarlar (LDAP / Güvenlik ve Uyumluluk / Bildirim Kanalları / Login logo) içinde kalan Türkçe alanlar çevrildi.</li>
                                <li><strong>(2.5.3) Sesli Arama / IVR birleştirildi:</strong> Ayrı "Sesli Arama" kanal türü "IVR" ile birleştirilip tek <b>"Sesli Arama / IVR"</b> seçeneği yapıldı (ikisi de aynı işi yapıyor). Mevcut Voice entegrasyonları otomatik taşınır.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Sürüm 2.5.2 — About İngilizce & düzeltmeler</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>(2.5.2) About tam İngilizce:</strong> Hakkında sayfası artık seçili dile göre sunucu tarafında çevrilir. Bundan sonra her değişiklik hem Türkçe hem İngilizce yazılır.</li>
                                <li><strong>(2.5.2) Koyu tema düzeltmesi:</strong> Dashboard altındaki servis durum kartları koyu temada artık beyaz kalmıyor.</li>
                                <li><strong>(2.5.2) WhatsApp şablonu geri geldi:</strong> Onaylı şablon (Content SID) alanı WhatsApp entegrasyonuna (Bildirim Kanalları) eklendi. Doluysa alarmlar yeniden butonlu interaktif şablon olarak gider; eski şablon otomatik geri yüklenir ve istediğin zaman değiştirilebilir.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Sürüm 2.5.x — Dil (TR/EN) & tema</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>Dil seçimi:</strong> Kullanıcı menüsüne <b>Dil</b> (Türkçe 🇹🇷 / English 🇬🇧) eklendi; seçim kullanıcı bazlı hatırlanır, arayüz çevrilir.</li>
                                <li><strong>Koyu tema:</strong> Sağ üstte adınıza tıklayın → <b>Tema</b> → Açık/Koyu (her birinin solunda renk yuvarlağı). Kullanıcı bazlı, girişler ve cihazlar arası hatırlanır.</li>
                                <li><strong>Grafik teması:</strong> Grafik eksen/kılavuz renkleri temaya uyar; UP/DOWN/ERROR/YAVAŞ/TOPLAM kutuları koyu temada okunur.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Sürüm 2.3.0 — Dashboard sekme birleştirme</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li>Ayrı "Dashboard" sekmesi kaldırıldı. Ana (filtresiz) görünüm artık "Dashboard'lar" içinde sabit <b>"Hepsi"</b> alt-sekmesi; silinemez, sıralanamaz.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Sürüm 2.2.x — Bildirim Kanalları (tek kutu)</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>Tek "Bildirim Kanalları" kutusu:</strong> SMS / WhatsApp / Sesli / IVR entegrasyonları Ayarlar'da tek yerden eklenir, düzenlenir, silinir ve aç/kapa yapılır. Eklerken tür seçilir; her entegrasyon kendi alıcı listesini kullanabilir. Kod gerekmez.</li>
                                <li><strong>Esnek entegrasyon modeli:</strong> tüm kanallar aynı şablonlu HTTP isteğiyle çalışır ({to}/{from}/{message}/{user}/{password}/{apikey}). Alarm anında servis bazlı aç/kapa (Mail/SMS/WhatsApp/Arama) ile eşleşen tüm aktif entegrasyonlar tetiklenir. Yerleşik Twilio ayarları otomatik entegrasyona taşındı.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Sürüm 2.1.x — Toplu düzenleme & tasarım</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>Aç/Kapa anahtarı:</strong> tüm aktif/pasif kutucukları modern toggle (kapalı gri, açık yeşil).</li>
                                <li><strong>Genişletilmiş toplu düzenleme:</strong> Servisler'de "Seçilenleri Düzenle" ile kontrol aralığı, yavaşlık eşiği ve CPU/RAM/Disk eşikleri toplu değiştirilebilir, toplu keyword eklenebilir. Aç/Kapat alanları segmentli buton (Dokunma/Aç/Kapat).</li>
                                <li><strong>Düzeltme:</strong> Dashboard'da Tip + Keyword filtresi birlikte seçilince <b>kesişim</b> alınır.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Sürüm 2.0.x — İnteraktif WhatsApp (Faz 4)</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>Şablonlu alarm + butonlar:</strong> onaylı WhatsApp şablonu ({{1}}..{{4}}) ile alarm; Başlat / Yeniden Başlat / Durdur butonları.</li>
                                <li><strong>İki yönlü müdahale:</strong> butona basınca gelen webhook ile servise uzaktan start/stop/restart uygulanır; sonuç WhatsApp'tan yanıtlanır.</li>
                                <li><strong>Yetki ve eşleme:</strong> numara → kullanıcı (Kullanıcılar'da telefon alanı); yalnızca <b>"Alarmlara müdahale"</b> yetkisi olanlar işlem yapar. Tüm işlemler Denetim'e yazılır.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Sürüm 1.8–1.9 — SMS & WhatsApp bildirimi</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>SMS / WhatsApp bildirimi (Twilio):</strong> servis DOWN/ERROR/RECOVERED olunca mesaj gider. Servis bazlı "Alarm Yönetimi" kanalları açar/kapatır. Özel HTTP SMS sağlayıcıları (ör. NetGSM) kod gerekmeden eklenir.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Sürüm 1.6–1.7 — Mutabakat, açıklamalar & düzeltmeler</p>
                            <ul class="list-disc ml-5 space-y-1.5 mb-3">
                                <li><strong>Mutabakat modülü:</strong> envanterimizi firmanın listesiyle (CSV/XLSX) çapraz karşılaştırır; eksik/fazla sunucular ve CPU/RAM/Disk/IP/OS uyuşmazlıkları. Tamamen bağımsız ve yetkiyle korunur.</li>
                                <li><strong>Servis açıklaması</strong> dashboard kartları, raporlar ve CSV'de; grafiğin "Servis Seç" filtresi artık kartlara da uygulanır.</li>
                                <li><strong>Uptime düzeltmesi:</strong> CPU/RAM/Disk eşik aşımları (ERROR) raporlarda artık kesinti sayılmaz.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mb-2">Sürüm 1.4–1.5 — Güvenlik sertleştirmesi & yetkilendirme (PCI DSS / ISO 27001 / NIST)</p>
                            <ul class="list-disc ml-5 space-y-1.5">
                                <li><strong>Granüler yetkilendirme</strong> (Kullanıcılar ekranı); CSRF, güvenli çerezler, HTTPS/HSTS, güvenlik başlıkları, kaba kuvvet koruması.</li>
                                <li><strong>Denetim kaydı</strong> tüm hassas işlemler için salt-okunur ekranla; ≥1 yıl saklama; 15 dk boşta zaman aşımı; hesap kilitleme; giden TLS doğrulaması varsayılan açık.</li>
                                <li><strong>Erişim gözden geçirme:</strong> AD grubundan düşen kullanıcılar senkronda pasifleşir, giriş yapamaz.</li>
                            </ul>
                            <p class="font-semibold text-slate-700 mt-3 mb-2">Önceki — Sürüm 1.3.0</p>
                            <ul class="list-disc ml-5 space-y-1.5">
                                <li>DOWN / ERROR sınıflandırması; Windows/Linux servis durum izleme + uzaktan başlat/durdur/yeniden başlat; 1 aya kadar zaman aralıkları; gelişmiş filtreleme.</li>
                            </ul>
                        }
                    </div>
                </div>
            </div>
            <div class="flex gap-3">
                <div class="w-44 shrink-0 font-medium text-slate-600"><i class="bi bi-gear-wide-connected text-brand-500"></i> @T("Yetenekler", "Capabilities")</div>
                <div class="text-slate-700 leading-relaxed">
                    @if (en)
                    {
                        <text>End-to-end service and infrastructure monitoring from a single console: databases (MySQL, MSSQL, Oracle),
                        Active Directory / LDAPS, DNS, DHCP, SFTP, Exchange / Exchange Online (SMTP &amp; IMAP),
                        HTTP/HTTPS endpoints, ICMP ping and TCP port checks, plus real-time
                        <strong>CPU / RAM / Disk health monitoring</strong> on Windows and Linux servers. Live-charted main screen,
                        tabbed and customizable multi-dashboards, CPU/RAM/Disk timelines,
                        date–time ranged availability reports going back up to 1 year,
                        average/peak usage statistics, CSV export/import, keyword/tag-based filtering,
                        automatic email notifications on threshold breaches and an instant "check now" feature.</text>
                    }
                    else
                    {
                        <text>Tek bir merkezden uçtan uca servis ve altyapı izleme: veritabanları (MySQL, MSSQL, Oracle),
                        Active Directory / LDAPS, DNS, DHCP, SFTP, Exchange / Exchange Online (SMTP &amp; IMAP),
                        HTTP/HTTPS uç noktaları, ICMP ping ve TCP port kontrolleri ile Windows ve Linux sunucularında
                        gerçek zamanlı <strong>CPU / RAM / Disk sağlık izleme</strong>. Canlı grafikli ana ekran,
                        sekmeli ve özelleştirilebilir çoklu dashboard'lar, CPU/RAM/Disk zaman çizelgeleri,
                        tarih–saat aralıklı ve 1 yıla kadar geriye dönük erişilebilirlik raporları,
                        ortalama/zirve kullanım istatistikleri, CSV dışa/içe aktarma, keyword/etiket bazlı filtreleme,
                        eşik aşımında otomatik e-posta bildirimleri ve anlık "şimdi kontrol et" özelliği.</text>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-6">
        <div class="card-head"><i class="bi bi-shield-lock text-brand-500"></i> @T("Güvenlik", "Security")</div>
        <div class="card-body">
            <p class="text-slate-700 mb-4">
                @if (en)
                {
                    <text>vMon never stores the account passwords used in monitoring tests as plain text.
                    All passwords are encrypted using <strong>DPAPI (Data Protection API)</strong>, the enterprise-grade
                    data protection facility of the Windows operating system.</text>
                }
                else
                {
                    <text>vMon, izleme testlerinde kullanılan hesap şifrelerini hiçbir zaman düz metin olarak saklamaz.
                    Tüm şifreler, Windows işletim sisteminin kurumsal standartlardaki veri koruma altyapısı olan
                    <strong>DPAPI (Data Protection API)</strong> ile şifrelenerek kaydedilir.</text>
                }
            </p>
            <ul class="space-y-3">
                @{
                    var itemsTr = new (string, string)[] {
                        ("Makineye özel şifreleme", "Şifreleme anahtarları doğrudan Windows tarafından, sunucuya özgü olarak yönetilir. Veritabanı dosyası kopyalansa dahi şifreler yalnızca bu sunucu üzerinde çözülebilir."),
                        ("Uygulama içinde anahtar yok", "Kodda veya yapılandırma dosyalarında gömülü herhangi bir şifreleme anahtarı bulunmaz; anahtar yönetimi tamamen işletim sistemine aittir."),
                        ("Yalnızca kullanım anında çözme", "Şifreler sadece servis kontrolü çalıştığı anda bellekte çözülür; diske yazılmaz ve günlük kayıtlarına geçmez."),
                        ("Arayüzde gizlilik", "Kayıtlı şifreler hiçbir ekranda geri gösterilmez; düzenleme sırasında yalnızca yeni şifre girilebilir."),
                        ("HashiCorp Vault entegrasyonu", "Kimlik bilgileri merkezi Vault kasasından kontrol anında güvenli biçimde çekilebilir; uygulama hiçbir gizli değeri kalıcı saklamak zorunda kalmaz."),
                        ("LDAP / Active Directory ile oturum açma", "Uygulamaya erişim kurumsal kimliklerle korunur; yalnızca belirlenen güvenlik grubunun üyeleri giriş yapabilir."),
                        ("Rol tabanlı yetkilendirme", "Yapılandırma ekranı yalnızca uygulama adminlerine açıktır; diğer kullanıcılar izleme ve raporlamayı tüm gücüyle kullanırken kritik ayarlar güvende kalır.")
                    };
                    var itemsEn = new (string, string)[] {
                        ("Machine-specific encryption", "Encryption keys are managed directly by Windows, specific to this server. Even if the database file is copied, passwords can only be decrypted on this server."),
                        ("No keys inside the application", "There are no encryption keys embedded in the code or configuration files; key management belongs entirely to the operating system."),
                        ("Decryption only at use time", "Passwords are decrypted in memory only while a service check runs; they are never written to disk or to logs."),
                        ("Confidential in the UI", "Saved passwords are never shown back on any screen; during editing only a new password can be entered."),
                        ("HashiCorp Vault integration", "Credentials can be securely pulled from a central Vault at check time; the application never has to persist any secret."),
                        ("LDAP / Active Directory sign-in", "Access is protected with corporate identities; only members of the designated security group can sign in."),
                        ("Role-based authorization", "The configuration screen is open only to application admins; other users get the full power of monitoring and reporting while critical settings stay safe.")
                    };
                    var secItems = en ? itemsEn : itemsTr;
                }
                @foreach (var item in secItems)
                {
                    <li class="flex gap-3">
                        <i class="bi bi-check-circle-fill text-emerald-500 mt-0.5"></i>
                        <span class="text-slate-700"><strong>@item.Item1:</strong> @item.Item2</span>
                    </li>
                }
            </ul>
        </div>
    </div>

    <div class="card mb-6" x-data="{ open:false }">
        <div class="card-head cursor-pointer select-none" @@click="open=!open">
            <span><i class="bi bi-patch-check text-brand-500"></i> @T("Regülasyon Uyumları", "Regulatory Compliance")</span>
            <i class="bi text-slate-400" :class="open ? 'bi-chevron-up' : 'bi-chevron-down'"></i>
        </div>
        <div class="card-body" x-show="open" x-cloak>
            <p class="text-sm text-slate-500 mb-4">
                @T("vMon'un sektör güvenlik düzenlemelerinin ilgili maddeleriyle eşlemesi. Bu bir öz-değerlendirme/haritalamadır (resmi sertifika değildir). Kapsanan çerçeveler: PCI DSS, NIST, ISO/IEC 27001, CIS, OWASP ASVS.",
                       "Mapping of vMon to relevant clauses of industry security frameworks. This is a self-assessment/mapping (not a formal certification). Frameworks covered: PCI DSS, NIST, ISO/IEC 27001, CIS, OWASP ASVS.")
            </p>
            @{
                var compTr = new (string ctrl, string refs, string desc)[] {
                    ("Rol tabanlı erişim (RBAC) + admin ayrımı", "PCI 7.x · ISO A.5.15/A.5.18 · NIST AC-2/AC-6 · CIS 6", "Ayarlar ve Kullanıcılar yalnız adminlere açık; her kullanıcı en az ayrıcalık ilkesiyle granüler izinlerle çalışır."),
                    ("Çok faktörlü doğrulama (OTP)", "PCI 8.5 · NIST IA-2 (AAL2) · ISO A.8.5", "Şifreden sonra e-posta/SMS/WhatsApp ile tek kullanımlık kod; yöneticiler için zorunlu kılınabilir."),
                    ("Kaba kuvvet kilitleme", "PCI 8.3.4 · NIST AC-7 · CIS 6", "Ardışık başarısız girişlerde hesap geçici kilitlenir (eşik ve süre yapılandırılır)."),
                    ("Boşta oturum zaman aşımı (15 dk)", "PCI 8.2.8 · NIST AC-12", "Belirli süre işlem yapılmazsa oturum otomatik sonlanır."),
                    ("Güçlü parola saklama (PBKDF2)", "PCI 8.3.x · NIST IA-5 · ISO A.8.24", "Yerel kullanıcı parolaları PBKDF2-SHA256 (100k iterasyon + tuz) ile saklanır; düz metin yoktur."),
                    ("Hesap yaşam döngüsü", "PCI 8.2.4-8.2.5 · NIST AC-2", "AD güvenlik grubundan düşen kullanıcılar senkronda pasifleşir ve giriş yapamaz."),
                    ("Denetim kaydı + saklama", "PCI 10.2/10.5.1 · ISO A.8.15 · NIST AU-2/AU-11 · CIS 8", "Tüm yönetimsel işlemler UTC zaman damgalı kaydedilir; ≥1 yıl saklanır; salt-okunur ekranla izlenir."),
                    ("Aktarımda şifreleme (TLS)", "PCI 4.2.1 · NIST SC-8 · ISO A.8.24", "LDAPS/Vault bağlantılarında sertifika doğrulaması varsayılan açık; uygulama için HTTPS/HSTS zorlanabilir."),
                    ("Sırların şifreli saklanması", "PCI 3.x · NIST SC-28 · ISO A.8.24", "İzleme kimlik bilgileri DPAPI ile şifrelidir; Vault ile hiç saklanmadan da çekilebilir."),
                    ("CSRF + enjeksiyon koruması", "OWASP ASVS · NIST SI-10", "Tüm formlarda antiforgery token; veritabanı erişimi parametrelidir (SQL enjeksiyonuna kapalı)."),
                    ("Backdoor yok / en az ayrıcalık", "NIST CM-7 · CIS 4", "Dosya tabanlı kurtarma/oturum atlama mekanizmaları kaldırıldı; uzaktan bypass yolu yoktur."),
                    ("Yedekleme & kurtarma", "ISO A.5.30 · NIST CP-9 · CIS 11", "Tutarlı (online) yedek + zamanlanmış yedek + geri yükleme ile iş sürekliliği."),
                    ("Hata gizliliği", "OWASP ASVS · NIST SI-11", "Hata sayfası teknik ayrıntı sızdırmaz; tam ayrıntı yalnız sunucu loglarındadır."),
                    ("Değiştirilemez denetim kaydı (hash-zinciri)", "PCI 10.3.x · NIST AU-9 · ISO A.8.15", "Her kayıt öncekinin SHA-256 hash'ini içerir; değiştirilen/silinen kayıt 'Bütünlüğü Doğrula' ile tespit edilir."),
                    ("Sıkı güvenlik başlıkları + CSP", "OWASP ASVS · NIST SC-7", "Content-Security-Policy, X-Frame-Options (clickjacking), nosniff, Referrer-Policy, Permissions-Policy."),
                    ("Yerel parola politikası + tekrar engeli", "PCI 8.3.6/8.3.7 · NIST IA-5", "Yapılandırılır min uzunluk/karmaşıklık; son N parola tekrar kullanılamaz."),
                    ("SIEM / syslog aktarımı", "PCI 10.5.4 · NIST AU-6 · ISO A.8.15", "Denetim olayları merkezi syslog sunucusuna iletilebilir (kurcalamaya dirençli, merkezi)."),
                    ("Şifreli yedekler", "PCI 3.x/9.4.1 · ISO A.8.24", "Yedek dosyaları AES-256 ile parolayla şifrelenebilir; kopyalansa bile parola olmadan açılamaz."),
                    ("Hız sınırlama (rate limiting)", "OWASP · NIST SC-5", "Kimlik doğrulama uçlarında IP başına istek sınırı — kaba kuvvet/DoS direnci."),
                    ("Sorumlu açıklama (security.txt)", "RFC 9116 · OWASP", "/.well-known/security.txt ile güvenlik iletişim noktası yayımlanır.")
                };
                var compEn = new (string ctrl, string refs, string desc)[] {
                    ("Role-based access (RBAC) + admin separation", "PCI 7.x · ISO A.5.15/A.5.18 · NIST AC-2/AC-6 · CIS 6", "Settings and Users are admin-only; every user runs with least-privilege granular permissions."),
                    ("Multi-factor authentication (OTP)", "PCI 8.5 · NIST IA-2 (AAL2) · ISO A.8.5", "One-time code via email/SMS/WhatsApp after the password; can be enforced for administrators."),
                    ("Brute-force lockout", "PCI 8.3.4 · NIST AC-7 · CIS 6", "Account is temporarily locked after consecutive failed logins (threshold and duration configurable)."),
                    ("Idle session timeout (15 min)", "PCI 8.2.8 · NIST AC-12", "Session ends automatically after a period of inactivity."),
                    ("Strong password storage (PBKDF2)", "PCI 8.3.x · NIST IA-5 · ISO A.8.24", "Local user passwords are stored with PBKDF2-SHA256 (100k iterations + salt); never in plain text."),
                    ("Account lifecycle", "PCI 8.2.4-8.2.5 · NIST AC-2", "Users removed from the AD security group are deactivated on sync and cannot sign in."),
                    ("Audit logging + retention", "PCI 10.2/10.5.1 · ISO A.8.15 · NIST AU-2/AU-11 · CIS 8", "All administrative actions are logged with UTC timestamps; retained ≥1 year; viewable read-only."),
                    ("Encryption in transit (TLS)", "PCI 4.2.1 · NIST SC-8 · ISO A.8.24", "Certificate validation is on by default for LDAPS/Vault; HTTPS/HSTS can be enforced for the app."),
                    ("Secrets encrypted at rest", "PCI 3.x · NIST SC-28 · ISO A.8.24", "Monitoring credentials are DPAPI-encrypted; with Vault they need not be stored at all."),
                    ("CSRF + injection protection", "OWASP ASVS · NIST SI-10", "Antiforgery token on all forms; database access is parameterized (closed to SQL injection)."),
                    ("No backdoors / least privilege", "NIST CM-7 · CIS 4", "File-based recovery/login-bypass mechanisms were removed; there is no remote bypass path."),
                    ("Backup & recovery", "ISO A.5.30 · NIST CP-9 · CIS 11", "Consistent (online) backup + scheduled backup + restore for business continuity."),
                    ("Error confidentiality", "OWASP ASVS · NIST SI-11", "The error page leaks no technical detail; full detail is only in server logs."),
                    ("Tamper-evident audit log (hash chain)", "PCI 10.3.x · NIST AU-9 · ISO A.8.15", "Each entry includes the previous one's SHA-256 hash; modified/deleted entries are caught by 'Verify Integrity'."),
                    ("Strict security headers + CSP", "OWASP ASVS · NIST SC-7", "Content-Security-Policy, X-Frame-Options (clickjacking), nosniff, Referrer-Policy, Permissions-Policy."),
                    ("Password policy + reuse prevention", "PCI 8.3.6/8.3.7 · NIST IA-5", "Configurable min length/complexity; the last N passwords cannot be reused."),
                    ("SIEM / syslog forwarding", "PCI 10.5.4 · NIST AU-6 · ISO A.8.15", "Audit events can be forwarded to a central syslog server (tamper-resistant, centralized)."),
                    ("Encrypted backups", "PCI 3.x/9.4.1 · ISO A.8.24", "Backup files can be AES-256 password-encrypted; even if copied they cannot be opened without the password."),
                    ("Rate limiting", "OWASP · NIST SC-5", "Per-IP request limit on authentication endpoints — brute-force/DoS resilience."),
                    ("Responsible disclosure (security.txt)", "RFC 9116 · OWASP", "A security contact is published at /.well-known/security.txt.")
                };
                var comp = en ? compEn : compTr;
            }
            <div class="overflow-x-auto">
                <table class="tbl text-sm">
                    <thead>
                        <tr>
                            <th class="whitespace-nowrap">@T("Uygulanan Kontrol", "Implemented Control")</th>
                            <th class="whitespace-nowrap">@T("İlgili Maddeler", "Mapped Clauses")</th>
                            <th>@T("Açıklama", "Explanation")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in comp)
                        {
                            <tr>
                                <td class="font-semibold text-slate-800 align-top"><i class="bi bi-check-circle-fill text-emerald-500"></i> @c.ctrl</td>
                                <td class="mono text-xs text-slate-500 align-top whitespace-nowrap">@c.refs</td>
                                <td class="text-slate-600 align-top">@c.desc</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <p class="text-xs text-slate-400 mt-3">
                @T("Not: Eşleme bilgilendirme amaçlıdır; resmi denetim/sertifika yerine geçmez. Tam veri-at-rest şifreleme ve değiştirilemez (hash-zincirli) denetim kaydı gibi ek kontroller yol haritasındadır.",
                   "Note: This mapping is informational and does not replace a formal audit/certification. Additional controls such as full data-at-rest encryption and tamper-evident (hash-chained) audit logging are on the roadmap.")
            </p>
        </div>
    </div>
</div>

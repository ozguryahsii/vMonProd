@model List<vMonitor.Models.AuditLog>
@{
    ViewData["Title"] = "Denetim Kaydı";
    var actions = ViewBag.Actions as List<string> ?? new List<string>();
}

<div class="flex items-center justify-between mb-5 flex-wrap gap-3">
    <h1 class="text-2xl font-bold text-slate-800 flex items-center gap-2"><i class="bi bi-clipboard-check text-brand-500"></i> Denetim Kaydı</h1>
    <span class="text-xs text-slate-400"><i class="bi bi-shield-lock"></i> Salt-okunur · PCI DSS 10.2 / ISO 27001 A.8.15 / NIST AU-2</span>
</div>

<form method="get" class="card mb-5">
    <div class="card-body grid grid-cols-1 md:grid-cols-12 gap-3 items-end">
        <div class="md:col-span-4">
            <label class="label">Ara (kullanıcı / hedef / IP / açıklama)</label>
            <input name="q" value="@ViewBag.Q" class="input" placeholder="örn. ahmet.yilmaz veya servis adı" />
        </div>
        <div class="md:col-span-3">
            <label class="label">Eylem türü</label>
            <select name="act" class="input">
                <option value="">— Tümü —</option>
                @foreach (var a in actions)
                {
                    <option value="@a" selected="@(ViewBag.Action as string == a)">@a</option>
                }
            </select>
        </div>
        <div class="md:col-span-2">
            <label class="label">Son (gün)</label>
            <input name="days" type="number" min="1" max="3650" value="@ViewBag.Days" placeholder="tümü" class="input" />
            <div class="hint">Boş = tüm kayıtlar</div>
        </div>
        <div class="md:col-span-3 flex gap-2">
            <button class="btn btn-primary"><i class="bi bi-funnel"></i> Filtrele</button>
            <a class="btn btn-outline" asp-action="Index"><i class="bi bi-x-lg"></i> Temizle</a>
        </div>
    </div>
</form>

<div class="card">
    <div class="card-head">
        <span><i class="bi bi-list-ul text-brand-500"></i> Kayıtlar</span>
        <span class="text-xs text-slate-400">@Model.Count kayıt gösteriliyor</span>
    </div>
    <div class="overflow-x-auto">
        <table class="tbl">
            <thead>
                <tr>
                    <th>Zaman</th>
                    <th>Kullanıcı</th>
                    <th>IP</th>
                    <th>Eylem</th>
                    <th>Hedef</th>
                    <th>Açıklama</th>
                    <th>Sonuç</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr><td colspan="7" class="text-center text-slate-400 py-8">Kayıt bulunamadı.</td></tr>
                }
                @foreach (var a in Model)
                {
                    <tr>
                        <td class="mono whitespace-nowrap">@a.At.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td class="font-medium">@a.User</td>
                        <td class="mono text-slate-500">@a.Ip</td>
                        <td><span class="badge pill-info">@a.Action</span></td>
                        <td>@a.Target</td>
                        <td class="text-slate-600">@a.Detail</td>
                        <td>
                            @if (a.Success)
                            {
                                <span class="badge pill-up"><i class="bi bi-check-circle"></i> Başarılı</span>
                            }
                            else
                            {
                                <span class="badge pill-down"><i class="bi bi-x-circle"></i> Başarısız</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

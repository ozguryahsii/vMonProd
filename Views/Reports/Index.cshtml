@{
    ViewData["Title"] = "Raporlar";
}

<div class="flex flex-wrap items-center justify-between gap-3 mb-5">
    <div>
        <h1 class="text-2xl font-bold text-slate-800 flex items-center gap-2"><i class="bi bi-bar-chart-line text-brand-500"></i> Erişilebilirlik Raporları</h1>
        <p class="text-sm text-slate-500 mt-0.5">Tarih–saat aralıklı geriye dönük analiz ve CSV dışa aktarma</p>
    </div>
</div>

<div class="card mb-5">
    <div class="card-body flex flex-wrap items-center gap-2">
        <div class="inline-flex rounded-xl border border-slate-200 overflow-hidden" id="quickRange">
            <button class="px-3 py-1.5 text-xs font-medium hover:bg-slate-50" data-days="1">24 saat</button>
            <button class="px-3 py-1.5 text-xs font-medium hover:bg-slate-50 border-l border-slate-200" data-days="7">7 gün</button>
            <button class="px-3 py-1.5 text-xs font-medium border-l border-slate-200" data-days="30">30 gün</button>
            <button class="px-3 py-1.5 text-xs font-medium hover:bg-slate-50 border-l border-slate-200" data-days="90">90 gün</button>
            <button class="px-3 py-1.5 text-xs font-medium hover:bg-slate-50 border-l border-slate-200" data-days="365">1 yıl</button>
        </div>
        <input type="datetime-local" id="dateFrom" class="input !w-auto !py-1.5" />
        <span class="text-slate-400">—</span>
        <input type="datetime-local" id="dateTo" class="input !w-auto !py-1.5" />
        <button id="btnLoad" class="btn btn-primary btn-sm"><i class="bi bi-search"></i> Getir</button>
        <button id="btnCsv" class="btn btn-success btn-sm"><i class="bi bi-filetype-csv"></i> CSV</button>
    </div>
</div>

<div class="card mb-5">
    <div class="card-head flex-wrap">
        <span><i class="bi bi-table text-brand-500"></i> Özet</span>
        <div class="flex flex-wrap items-center gap-2">
            <input type="text" id="filterText" class="input !w-48 !py-1.5" placeholder="Ad / hedef / etiket ara..." />
            <select id="filterType" class="input !w-auto !py-1.5"><option value="">Tüm Tipler</option></select>
            <select id="filterKeyword" class="input !w-auto !py-1.5"><option value="">Tüm Etiketler</option></select>
            <label class="flex items-center gap-1.5 text-sm text-slate-600 cursor-pointer">
                <input class="switch" type="checkbox" id="filterOutageOnly" /> Sadece kesintili
            </label>
            <label class="flex items-center gap-1.5 text-sm text-slate-600 cursor-pointer">
                <input class="switch" type="checkbox" id="filterErrorOnly" /> Sadece hatalı
            </label>
            <span id="filterCount" class="text-slate-400 text-xs"></span>
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="tbl" id="summaryTable">
            <thead id="summaryHead">
                <tr>
                    <th>Servis</th><th>Tip</th>
                    <th class="text-right">Kontrol</th><th class="text-right">Uptime</th>
                    <th class="text-right">Kesinti</th><th class="text-right">Toplam Kesinti</th>
                    <th class="text-right">Ort. Yanıt</th><th></th>
                </tr>
            </thead>
            <tbody id="summaryBody">
                <tr><td colspan="8" class="text-center text-slate-400 py-6"><i class="bi bi-arrow-repeat animate-spin"></i> Yükleniyor...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<div class="card hidden" id="detailCard">
    <div class="card-head">
        <span><i class="bi bi-graph-up text-brand-500"></i> <span id="detailTitle">Detay</span></span>
        <button class="text-slate-400 hover:text-slate-700" onclick="document.getElementById('detailCard').classList.add('hidden')"><i class="bi bi-x-lg"></i></button>
    </div>
    <div class="card-body" id="detailBody"></div>
</div>

@section Scripts {
    <script src="~/js/reports.js" asp-append-version="true"></script>
}

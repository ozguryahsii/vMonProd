@model DashboardDef
@{
    ViewData["Title"] = Model.Name;
}

<div class="flex flex-wrap items-center justify-between gap-3 mb-5">
    <h1 class="text-2xl font-bold text-slate-800 flex items-center gap-2"><i class="bi bi-display text-brand-500"></i> @Model.Name</h1>
    <div class="flex items-center gap-2">
        <span id="lastRefresh" class="text-slate-400 text-xs"></span>
        <select id="rangeSelect" class="input !w-auto !py-1.5">
            <option value="60">Son 1 saat</option>
            <option value="180" selected>Son 3 saat</option>
            <option value="360">Son 6 saat</option>
            <option value="720">Son 12 saat</option>
            <option value="1440">Son 24 saat</option>
            <option value="10080">Son 7 gün</option>
            <option value="43200">Son 1 ay</option>
        </select>
        <a class="btn btn-outline btn-sm" asp-action="Index"><i class="bi bi-arrow-left"></i> Dashboard'lar</a>
    </div>
</div>

<div class="grid grid-cols-2 lg:grid-cols-5 gap-3 mb-5">
    <button type="button" class="stat stat-btn cursor-pointer select-none" data-filter="up"><div class="stat-num text-emerald-500" id="sumUp">-</div><div class="stat-label">UP</div></button>
    <button type="button" class="stat stat-btn cursor-pointer select-none" data-filter="down"><div class="stat-num text-rose-500" id="sumDown">-</div><div class="stat-label">DOWN</div></button>
    <button type="button" class="stat stat-btn cursor-pointer select-none" data-filter="error"><div class="stat-num text-orange-500" id="sumError">-</div><div class="stat-label">ERROR</div></button>
    <button type="button" class="stat stat-btn cursor-pointer select-none" data-filter="slow"><div class="stat-num text-amber-500" id="sumSlow">-</div><div class="stat-label">Yavaş</div></button>
    <button type="button" class="stat stat-btn cursor-pointer select-none" data-filter="all"><div class="stat-num text-slate-600" id="sumTotal">-</div><div class="stat-label">Toplam</div></button>
</div>

<div class="card mb-5">
    <div class="card-head">
        <span><i class="bi bi-graph-up text-brand-500"></i> Yanıt Süreleri</span>
        <div class="relative" x-data="{open:false}">
            <button type="button" class="btn btn-outline btn-sm" @@click="open=!open">
                <i class="bi bi-funnel"></i> Servis Seç <i class="bi bi-chevron-down text-[10px]"></i>
            </button>
            <div x-show="open" @@click.outside="open=false" x-cloak
                 class="absolute right-0 mt-1 w-80 max-h-96 overflow-y-auto bg-white border border-slate-200 rounded-xl shadow-xl p-2 z-30" id="chartFilterMenu">
                <div class="text-slate-400 text-sm p-2">Yükleniyor...</div>
            </div>
        </div>
    </div>
    <div class="card-body" style="height: 360px;"><canvas id="liveChart"></canvas></div>
</div>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-4 mb-5 hidden" id="healthSection">
    <div class="card"><div class="card-head"><i class="bi bi-cpu text-brand-500"></i> CPU Kullanımı</div><div class="card-body" style="height:240px;"><canvas id="cpuChart"></canvas></div></div>
    <div class="card"><div class="card-head"><i class="bi bi-memory text-brand-500"></i> RAM Kullanımı</div><div class="card-body" style="height:240px;"><canvas id="ramChart"></canvas></div></div>
    <div class="card"><div class="card-head"><i class="bi bi-device-hdd text-brand-500"></i> Disk Doluluk</div><div class="card-body" style="height:240px;"><canvas id="diskChart"></canvas></div></div>
</div>

@if (User.Can(Perms.ServicesCheck))
{
    <div class="flex justify-end mb-3">
        <button id="btnCheckBoard" class="btn btn-primary btn-sm"><i class="bi bi-arrow-repeat"></i> Görünenleri Kontrol Et</button>
    </div>
}

<div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-4" id="serviceCards"></div>

<div class="modal-overlay" id="historyModal" hidden>
    <div class="modal-card fade-in">
        <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100">
            <h5 class="font-semibold text-slate-700" id="historyTitle">Geçmiş</h5>
            <div class="flex items-center gap-2">
                <select id="histRange" class="input !w-auto !py-1.5 text-sm">
                    <option value="60">Son 1 saat</option>
                    <option value="180">Son 3 saat</option>
                    <option value="360">Son 6 saat</option>
                    <option value="720">Son 12 saat</option>
                    <option value="1440" selected>Son 24 saat</option>
                    <option value="10080">Son 7 gün</option>
                    <option value="43200">Son 1 ay</option>
                </select>
                <button type="button" class="text-slate-400 hover:text-slate-700" data-modal-close><i class="bi bi-x-lg"></i></button>
            </div>
        </div>
        <div class="p-5 max-h-[70vh] overflow-y-auto" id="historyBody"></div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chartjs/chart.umd.min.js" asp-append-version="true"></script>
    <script src="~/js/livechart.js" asp-append-version="true"></script>
    <script src="~/js/dash-actions.js" asp-append-version="true"></script>
    <script>const DASHBOARD_ID = @Model.Id;</script>
    <script src="~/js/dashboard-view.js" asp-append-version="true"></script>
}
